						"Resultado":false
					},
					{	"Id":null,
						"Descricao":"EMPRESAS RELACIONADAS COM RESTRI├ć├āO",
						"Resultado":true
					},
					{	"Id":null,
						"Descricao":"S├ōCIO POSSUI CCF",
						"Resultado":true
					},
					{	"Id":null,
						"Descricao":"S├ōCIO POSSUI RESTRI├ć├ĢES",
						"Resultado":true
					},
					{	"Id":null,
						"Descricao":"S├ōCIO POSSUI REGISTRO DE ├ōBITO",
						"Resultado":true
					},
					{	"Id":null,
						"Descricao":"AUSENCIA DE PASSAGENS",
						"Resultado":true
					},
					{	"Id":null,
						"Descricao":"PASSAGENS MAIOR QUE 50% REFERENTE A M├ēDIA DOS ├ÜLTIMOS 12 MESES",
						"Resultado":true
					},
					{	"Id":null,
						"Descricao":"ENDERE├ćO RETORNA VINCULADO ",
						"Resultado":false
					},	
					{	"Id":null,
						"Descricao":"TELEFONE RETORNA VINCULADO ",
						"Resultado":false
					}],
					"InformacoesAdicionais":[{"Grupo":"Parecer","Nome":"Regra Decisora","Valor":"ENDERE├ćO RETORNA VINCULADO "}]}
	*/
	Aadd(aUpdTblB2E,{"TB2_NIDUNQ",cUnqTb2 })

	Aadd(aUpdTblB2E,{"TB2_IDB2E" ,Iif(jRet["PropostaId"]<> Nil,jRet["PropostaId"],"")})

	Aadd(aUpdTblB2E,{"TB2_CDPROP",jRet["CodigoProposta"] })

	Aadd(aUpdTblB2E,{"TB2_CDINST",cCodInst })

	Aadd(aUpdTblB2E,{"TB2_SUCESS",Iif(jRet["Sucesso"],"true","false") })

	Aadd(aUpdTblB2E,{"TB2_PPROCE", Iif(jRet["PropostaProcessada"],"true","false")  })

	Aadd(aUpdTblB2E,{"TB2_STS_ID", Iif(jRet["StatusProposta"] <> Nil,cValToChar(jRet["StatusProposta"]['Id']),"") })

	Aadd(aUpdTblB2E,{"TB2_STS_NM", Iif(jRet["StatusProposta"] <> Nil,jRet["StatusProposta"]["Nome"],"")})

	Aadd(aUpdTblB2E,{"TB2_STS_DS", Iif(jRet["StatusProposta"] <> Nil,cValToChar(jRet["StatusProposta"]["Descricao"]),"") })

	Aadd(aUpdTblB2E,{"TB2_STS_SC",  Iif(jRet["Score"] <> Nil,jRet["Score"] , 0 )})

	Aadd(aUpdTblB2E,{"TB2_STS_LC",  Iif(jRet["LimiteConcedido"] <> Nil ,jRet["LimiteConcedido"],0) })

	sfUpdate("T_B2EWEBHK"+cEmpAnt/*cInTble*/,aUpdTblB2E/*aInUpd*/,jRet:toJson()/*cInJson*/)


	If jRet["InformacoesAdicionais"] <> Nil
		For nX := 1 To Len(jRet["InformacoesAdicionais"])
			aUpdTblB2E	:= {}
			//Campos
			Aadd(aUpdTblB2E,{"TB3_NIDUNQ",cUnqTb2 })

			Aadd(aUpdTblB2E,{"TB3_ITEM", StrZero(nX,3)})

			Aadd(aUpdTblB2E,{"TB3_TIPO"	, "I" })

			Aadd(aUpdTblB2E,{"TB3_GRUPO",  jRet["InformacoesAdicionais"][nX]["Grupo"] })

			Aadd(aUpdTblB2E,{"TB3_NOME",   jRet["InformacoesAdicionais"][nX]["Nome"]})

			Aadd(aUpdTblB2E,{"TB3_VALOR",  jRet["InformacoesAdicionais"][nX]["Valor"]})

			sfUpdate("T_B2EWEBIA"+cEmpAnt/*cInTble*/,aUpdTblB2E/*aInUpd*/,jRet["InformacoesAdicionais"][nX]:ToJson()/*cInJson*/)
		Next
	Endif

	If jRet["Mensagens"] <> Nil
		For nX := 1 To Len(jRet["Mensagens"])
			aUpdTblB2E	:= {}
			//Campos
			Aadd(aUpdTblB2E,{"TB3_NIDUNQ",cUnqTb2 })

			Aadd(aUpdTblB2E,{"TB3_ITEM", StrZero(nX,3)})

			Aadd(aUpdTblB2E,{"TB3_TIPO"	, "M" })

			Aadd(aUpdTblB2E,{"TB3_MSGTP", jRet["Mensagens"][nX]["Tipo"] })

			Aadd(aUpdTblB2E,{"TB3_MSGCD",  jRet["Mensagens"][nX]["Codigo"]  })

			Aadd(aUpdTblB2E,{"TB3_MSGDS",  jRet["Mensagens"][nX]["Descricao"] })

			Aadd(aUpdTblB2E,{"TB3_MSGVI",  jRet["Mensagens"][nX]["ValorInformado"] })

			sfUpdate("T_B2EWEBIA"+cEmpAnt/*cInTble*/,aUpdTblB2E/*aInUpd*/,jRet["Mensagens"][nX]:ToJson()/*cInJson*/)
		Next
	Endif
Return


Static Function sfGetStsPropEhCli(cInCodProp)

	Local 		aHeader 	:= {}
	Local 		cUrl 		:= "https://cred-api.b2esistemas.com.br/parecer/v1.0.0/pareceres?"
	Local 		cCodInst 	:= "codigoInstituicao=5FDADC7A-B503-468C-9628-B4E3B1F8464D"
	Local 		cCodPerg 	:= "codigoInstituicao=" + cCodInst
	Local 		cCodProp	:= "codigoProposta="  //202504070401-123456"
	Local 		cGetParms 	:= ""
	Local 		nTimeOut 	:= 120
	Local 		cHeaderGet 	:= ""
	Local 		cToken		:= sfTokNew()
	Local 		aUpdTblB2E	:= {}
	Local 		nX
	Local 		cUnqTb2 	:= xFilial("SC5")+cInNumPed+DTOS(Date())+StrTran(Time(),":")

	DbSelectArea("SC5")
	DbSetOrder(1)
	If !DbSeek(xFilial("SC5")+cInNumPed)
		Return
	Endif

	cCodProp += SC5->C5_FILIAL + "-" + IIf(!Empty(SC5->C5_IDAJILI),"V"+StrZero(SC5->C5_IDAJILI,8), SC5->C5_NUM)

	Aadd( aHeader,'User-Agent: Mozilla/4.0 (compatible; Protheus ' + GetBuild() + ')' )
	Aadd( aHeader,"Content-Type: application/json")
	Aadd( aHeader,'Authorization: Bearer '+cToken)

	cRetorno := HttpGet( cUrl + cCodPerg + "&" + cCodProp , cGetParms, nTimeOut, aHeader, @cHeaderGet )

	If ValType(cRetorno) <> "C"
		MsgAlert("Erro de acesso a pßgina de Pedidos '" +cUrl +"'. Favor contatar o TI.", ProcName(0)+"."+ Alltrim(Str(ProcLine(0))))
		Return
	Endif

	jRet := JSonObject():New()
	jRet:FromJson(cRetorno)

	/*
	{
    "Sucesso": true,
    "Mensagens": [],
    "CodigoProposta": "202504070401-123456",
    "PropostaId": "200000581212",
    "PropostaProcessada": false,
    "StatusProposta": {
        "Id": 0,
        "Nome": "EM PROCESSAMENTO",
        "Descricao": null
    },
    "Score": null,
    "LimiteConcedido": null,
    "Alertas": null,
    "InformacoesAdicionais": []
	}

	{"Sucesso":true,"Mensagens":[],"CodigoProposta":"202505120401-090522","PropostaId":"200000613850","PropostaProcessada":true,"StatusProposta":{"Id":1,"Nome":"AGUARDANDO AN├ØLISE","Descricao":null},"Score":959.0000,"LimiteConcedido":null,"Alertas":[{"Id":null,"Descricao":"FILIAL ENVIADA","Resultado":null},{"Id":null,"Descricao":"CNAE ACEIT├ØVEL","Resultado":false},{"Id":null,"Descricao":"PONTUALIDADE DE PAGAMENTO SERASA MENOR QUE 85%","Resultado":true},{"Id":null,"Descricao":"SCORE FUNCIONAL","Resultado":true},{"Id":null,"Descricao":"SCORE BAIX├ØSSIMO RISCO ","Resultado":true},{"Id":null,"Descricao":"SITUA├ć├āO CADASTRAL ATIVA","Resultado":true},{"Id":null,"Descricao":"FUNDA├ć├āO MAIOR IGUAL A 6 MESES","Resultado":true},{"Id":null,"Descricao":"SINTEGRA HABILITADO ","Resultado":true},{"Id":null,"Descricao":"EMPRESA POSSUI FAL├ŖNCIAS","Resultado":true},{"Id":null,"Descricao":"EMPRESA POSSUI CCF","Resultado":true},{"Id":null,"Descricao":"EMPRESA POSSUI RESTRI├ć├ĢES","Resultado":false},{"Id":null,"Descricao":"EMPRESAS RELACIONADAS COM RESTRI├ć├āO","Resultado":true},{"Id":null,"Descricao":"S├ōCIO POSSUI CCF","Resultado":true},{"Id":null,"Descricao":"S├ōCIO POSSUI RESTRI├ć├ĢES","Resultado":true},{"Id":null,"Descricao":"S├ōCIO POSSUI REGISTRO DE ├ōBITO","Resultado":true},{"Id":null,"Descricao":"AUSENCIA DE PASSAGENS","Resultado":true},{"Id":null,"Descricao":"PASSAGENS MAIOR QUE 50% REFERENTE A M├ēDIA DOS ├ÜLTIMOS 12 MESES","Resultado":true},{"Id":null,"Descricao":"ENDERE├ćO RETORNA VINCULADO ","Resultado":false},{"Id":null,"Descricao":"TELEFONE RETORNA VINCULADO ","Resultado":false}],"InformacoesAdicionais":[{"Grupo":"Parecer","Nome":"Regra Decisora","Valor":"ENDERE├ćO RETORNA VINCULADO "}]}

	*/
	Aadd(aUpdTblB2E,{"TB2_NIDUNQ",cUnqTb2 })

	Aadd(aUpdTblB2E,{"TB2_IDB2E" ,jRet["PropostaId"] })

	Aadd(aUpdTblB2E,{"TB2_CDPROP",jRet["CodigoProposta"] })

	Aadd(aUpdTblB2E,{"TB2_CDINST",cCodInst })

	Aadd(aUpdTblB2E,{"TB2_SUCESS",Iif(jRet["Sucesso"],"true","false") })

	Aadd(aUpdTblB2E,{"TB2_PPROCE", Iif(jRet["PropostaProcessada"],"true","false")  })

	Aadd(aUpdTblB2E,{"TB2_STS_ID", cValToChar(jRet["StatusProposta"]['Id']) })

	Aadd(aUpdTblB2E,{"TB2_STS_NM", jRet["StatusProposta"]["Nome"] })

	Aadd(aUpdTblB2E,{"TB2_STS_DS", cValToChar(jRet["StatusProposta"]["Descricao"]) })

	Aadd(aUpdTblB2E,{"TB2_STS_SC",  Iif(jRet["Score"] <> Nil,Val(jRet["Score"]) , 0 )})

	Aadd(aUpdTblB2E,{"TB2_STS_LC",  Iif(jRet["LimiteConcedido"] <> Nil , Val(jRet["LimiteConcedido"]),0) })

	sfUpdate("T_B2EWEBHK"+cEmpAnt/*cInTble*/,aUpdTblB2E/*aInUpd*/,jRet:toJson()/*cInJson*/)



	For nX := 1 To Len(jRet["InformacoesAdicionais"])
		aUpdTblB2E	:= {}
		//Campos
		Aadd(aUpdTblB2E,{"TB3_NIDUNQ",cUnqTb2 })

		Aadd(aUpdTblB2E,{"TB3_ITEM", StrZero(nX,3)})

		Aadd(aUpdTblB2E,{"TB3_TIPO"	, "I" })

		Aadd(aUpdTblB2E,{"TB3_GRUPO",  jRet["InformacoesAdicionais"][nX]["Grupo"] })

		Aadd(aUpdTblB2E,{"TB3_NOME",   jRet["InformacoesAdicionais"][nX]["Nome"]})

		Aadd(aUpdTblB2E,{"TB3_VALOR",  jRet["InformacoesAdicionais"][nX]["Valor"]})

		sfUpdate("T_B2EWEBIA"+cEmpAnt/*cInTble*/,aUpdTblB2E/*aInUpd*/,jRet["InformacoesAdicionais"][nX]:ToJson()/*cInJson*/)
	Next

	For nX := 1 To Len(jRet["Mensagens"])
		aUpdTblB2E	:= {}
		//Campos
		Aadd(aUpdTblB2E,{"TB3_NIDUNQ",cUnqTb2 })

		Aadd(aUpdTblB2E,{"TB3_ITEM", StrZero(nX,3)})

		Aadd(aUpdTblB2E,{"TB3_TIPO"	, "M" })

		Aadd(aUpdTblB2E,{"TB3_MSGTP", jRet["Mensagens"][nX]["Tipo"] })

		Aadd(aUpdTblB2E,{"TB3_MSGCD",  jRet["Mensagens"][nX]["Codigo"]  })

		Aadd(aUpdTblB2E,{"TB3_MSGDS",  jRet["Mensagens"][nX]["Descricao"] })

		Aadd(aUpdTblB2E,{"TB3_MSGVI",  jRet["Mensagens"][nX]["ValorInformado"] })

		sfUpdate("T_B2EWEBIA"+cEmpAnt/*cInTble*/,aUpdTblB2E/*aInUpd*/,jRet["Mensagens"][nX]:ToJson()/*cInJson*/)
	Next
Return



Static Function SerLibCrRS(cCliente,cLoja,lBloqueia,lRejeita,nRisco,nPrinad)
	Local aArea     := GetArea()
	Local lQuery    := .F.
	Local lLibera   := .F.
	Local cAliasSC9 := "SC9"
	Local nLimite   := GetNewPar("MV_SERASA1",0)
	Local nLimite3  := GetNewPar("MV_SERASA3",9999)
	Local cQuery    := ""

	Default lBloqueia := .F.
	Default lRejeita  := .F.
	Default nRisco    := 0
	Default nPriNad   := 0

	If nRisco == -1 //.And. nPriNad == -1
		If lRejeita .Or. lBloqueia
			lLibera := .F.
		Endif
	Else
		If !lBloqueia
			If nRisco >= nLimite //.And. nPriNad >= nLimite2
				lLibera := .T.
			EndIf
			If nRisco <= nLimite3 //.And. nPriNad <= nLimite4
				lRejeita := .T.
			EndIf
		EndIf
	EndIf
	If lRejeita .Or. lBloqueia
		lLibera := .F.
	EndIf

	cAliasSC9 := "SERLIBCRRS"

	cQuery := "SELECT C9_FILIAL,C9_CLIENTE,C9_LOJA,C9_BLCRED,R_E_C_N_O_ SC9RECNO "
	cQuery += RetSqlName("SC9")+" SC9 "
	cQuery += "WHERE SC9.C9_FILIAL='"+xFilial("SC9")+"' AND "
	cQuery += "SC9.C9_CLIENTE='"+cCliente+"' AND "
	cQuery += "SC9.C9_LOJA='"+cLoja+" AND "
	cQuery += "(SC9.C9_BLCRED<>'"+Space(Len(SC9->C9_BLCRED))+"' AND "
	cQuery += "SC9.C9_BLCRED<>'09') AND "
	cQuery += "SC9.D_E_L_E_T_=' ' "

	cQuery := ChangeQuery(cQuery)

	dbUseArea(.T.,"TOPCONN",TcGenQry(,,cQuery),cAliasSC9)

	While (!Eof() .And. (cAliasSC9)->C9_FILIAL == xFilial("SC9") .And.;
			(cAliasSC9)->C9_CLIENTE == cCliente .And.;
			(cAliasSC9)->C9_LOJA == cLoja )
		If (cAliasSC9)->C9_BLCRED <> Space(Len((cAliasSC9)->C9_BLCRED)) .And.;
				(cAliasSC9)->C9_BLCRED <> '09'
			If lQuery
				SC9->(MsGoto((cAliasSC9)->SC9RECNO))
			EndIf
			Begin Transaction
				RecLock("SC9")
				If SC9->C9_BLCRED <> Space(Len(SC9->C9_BLCRED)) .And. SC9->C9_BLCRED <> '09'
					If lLibera
						a450Grava(1,.T.,.F.)
					ElseIf lRejeita
						a450Grava(2,.T.,.F.)
					Else
						If SC9->(FIELDPOS("C9_BLINF"))<>0
							RecLock("SC9")
							SC9->C9_BLINF := "RECOMENDA-SE ANALISE MANUAL - IP23 SERASA"
							MsUnLock()
						EndIf
					EndIf
				EndIf
				MsUnLock()
			End Transaction
		EndIf
		dbSelectArea(cAliasSC9)
		dbSkip()
	EndDo
	If lQuery
		dbSelectArea(cAliasSC9)
		dbCloseArea()
		dbSelectArea("SC9")
	EndIf
	RestArea(aArea)
Return(.T.)




Static Function SerMsgRef(cCliente,cLoja,cMsgBlq,cMsgFea,cMsgRsk)
	Local aArea     := GetArea()
	Local aAreaSAO  := SAO->(GetArea())
	Local lQuery    := .F.
	Local cAliasSAO := "SAO"
	Local aStruSAO  := {}
	Local cQuery    := ""
	Local nX        := 0

	Default cMsgBlq := ""
	Default cMsgFea := ""
	Default cMsgRsk := ""

	If !Empty(cMsgBlq+cMsgRsk+cMsgFea)
		cAliasSAO := "SerMsgRef"
		aStruSAO  := SAO->(dbStruct())
		lQuery    := .T.

		cQuery := "SELECT SAO.*,SAO.R_E_C_N_O_ SAORECNO "
		cQuery += "FROM "+RetSqlName("SAO")+" SAO "
		cQuery += "WHERE SAO.AO_FILIAL='"+xFilial("SAO")+"' AND "
		cQuery += "SAO.AO_CLIENTE='"+SA1->A1_COD+"' AND "
		cQuery += "SAO.AO_LOJA='"+SA1->A1_LOJA+"' AND "
		cQuery += "SAO.AO_TIPO='1' AND "
		cQuery += "SAO.AO_NOMINS LIKE '%SERASA%' AND "
		cQuery += "(SAO.AO_NOMFUN LIKE '%MSGBLOCO%' OR "
		cQuery += "SAO.AO_NOMFUN LIKE '%MSGFEATURE%' OR "
		cQuery += "SAO.AO_NOMFUN LIKE '%MSGRISKSCORING%' ) AND "
		cQuery += "SAO.D_E_L_E_T_=' ' "

		cQuery := ChangeQuery(cQuery)

		dbUseArea(.T.,"TOPCONN",TcGenQry(,,cQuery),cAliasSAO)

		For nX := 1 To Len(aStruSAO)
			If aStruSAO[nX][2] <> "C"
				TcSetField(cAliasSAO,aStruSAO[nX][1],aStruSAO[nX][2],aStruSAO[nX][3],aStruSAO[nX][4])
			EndIf
		Next nX

		While !Eof() .And. (cAliasSAO)->AO_FILIAL == xFilial("SAO") .And.;
				(cAliasSAO)->AO_CLIENTE == cCliente .And.;
				(cAliasSAO)->AO_LOJA == cLoja .And.;
				(cAliasSAO)->AO_TIPO == "1"
			If "SERASA"$Upper((cAliasSAO)->AO_NOMINS)
				Do Case
				Case "MSGBLOCO"$Upper((cAliasSAO)->AO_NOMFUN)
					If lQuery
						SAO->(MsGoto(SAORECNO))
					EndIf
					RecLock("SAO")
					SAO->AO_DATA   := dDataBase
					SAO->AO_OBSERV := cMsgBlq
					MsUnLock()
					cMsgBlq := ""
				Case "MSGFEATURE"$Upper((cAliasSAO)->AO_NOMFUN)
					If lQuery
						SAO->(MsGoto(SAORECNO))
					EndIf
					RecLock("SAO")
					SAO->AO_DATA   := dDataBase
					SAO->AO_OBSERV := cMsgFea
					MsUnLock()
					cMsgFea := ""
				Case "MSGRISKSCORING"$Upper((cAliasSAO)->AO_NOMFUN)
					If lQuery
						SAO->(MsGoto(SAORECNO))
					EndIf
					RecLock("SAO")
					SAO->AO_DATA   := dDataBase
					SAO->AO_OBSERV := cMsgRsk
					MsUnLock()
					cMsgRsk := ""
				EndCase
			EndIf
			If Empty(cMsgBlq+cMsgRsk+cMsgFea)
				Exit
			EndIf
			dbSelectArea(cAliasSAO)
			dbSkip()
		EndDo
		If lQuery
			dbSelectArea(cAliasSAO)
			dbCloseArea()
			dbSelectArea("SAO")
		EndIf
		Do Case
		Case !Empty(cMsgBlq)
			RecLock("SAO",.T.)
			SAO->AO_FILIAL := xFilial("SAO")
			SAO->AO_CLIENTE:= cCliente
			SAO->AO_LOJA   := cLoja
			SAO->AO_TIPO   := "1"
			SAO->AO_NOMINS := "SERASA - IP23"
			SAO->AO_NOMFUN := "MSGBLOCO"
			SAO->AO_DATA   := dDataBase
			SAO->AO_OBSERV := cMsgBlq
			MsUnLock()
		Case !Empty(cMsgFea)
			RecLock("SAO",.T.)
			SAO->AO_FILIAL := xFilial("SAO")
			SAO->AO_CLIENTE:= cCliente
			SAO->AO_LOJA   := cLoja
			SAO->AO_TIPO   := "1"
			SAO->AO_NOMINS := "SERASA - IP23"
			SAO->AO_NOMFUN := "MSGFEATURE"
			SAO->AO_DATA   := dDataBase
			SAO->AO_OBSERV := cMsgFea
			MsUnLock()
		Case !Empty(cMsgRsk)
			RecLock("SAO",.T.)
			SAO->AO_FILIAL := xFilial("SAO")
			SAO->AO_CLIENTE:= cCliente
			SAO->AO_LOJA   := cLoja
			SAO->AO_TIPO   := "1"
			SAO->AO_NOMINS := "SERASA - IP23"
			SAO->AO_NOMFUN := "MSGRISKSCORING"
			SAO->AO_DATA   := dDataBase
			SAO->AO_OBSERV := cMsgRsk
			MsUnLock()
		EndCase
	EndIf
	RestArea(aAreaSAO)
	RestArea(aArea)
Return(.T.)

