Static Function sfGetLastPgto(cInCod,cInLoja,nInOpc)
//Data do ·ltimo pagamento + dias de atraso de tal pagamento (considerar somente portador 341 e 033 e Motivo Baixa ōNormalö para essa informańŃo)
	Local 	cTextRet 		:= ""
	Local 	aAreaOld 		:= GetArea()
	Local 	cQry 			:= ""

	cQry := "SELECT E5_DATA,E5_VENCTO "
	cQry += "  FROM " + RetSqlName("SE5") + " E5 "
	cQry += " WHERE D_E_L_E_T_ = ' ' "
	cQry += "   AND E5_CLIENTE = '" + cInCod + "' "
	cQry += "   AND E5_LOJA = '" + cInLoja + "' "
	cQry += "   AND E5_MOTBX ='NOR' "
	cQry += "   AND E5_RECPAG ='R' "
	cQry += "   AND E5_TIPODOC NOT IN('JR') "
	cQry += "   AND E5_TIPO NOT IN('RA') "	
	cQry += "   AND E5_BANCO IN('341','033') "
	cQry += "   AND E5_FILIAL " + cFilSE5
	cQry += " ORDER BY R_E_C_N_O_ DESC "

	TcQuery cQry New Alias "QSE5"

	If !Eof()
		If nInOpc == 1
			cTextRet 	:= "┌ltima Baixa: " + DTOC(STOD(QSE5->E5_DATA)) + " - Dias Atraso: " + cValToChar(STOD(QSE5->E5_DATA) - STOD(QSE5->E5_VENCTO))
		ElseIf nInOpc == 2 
			cTextRet 	:= DTOC(STOD(QSE5->E5_DATA)) 
		Endif 
	Endif
	QSE5->(DbCloseArea())

	RestArea(aAreaOld)

Return cTextRet




Static Function sfGetMediaAtraso(cInCod,cInLoja)
//Mķdia de dias de atraso dos ·ltimos 12 meses (considerar somente portador 341 e 033 e Motivo Baixa ōNormal para essa informańŃo)
	Local 	cTextRet 		:= ""
	Local 	aAreaOld 		:= GetArea()
	Local 	cQry 			:= ""

	cQry := "SELECT AVG(DATEDIFF(DD,CONVERT(DATE,E5_VENCTO  ) , CONVERT(DATE,E5_DATA))) MEDIA_DIAS  "
	cQry += "  FROM " + RetSqlName("SE5") + " E5 "
	cQry += " WHERE D_E_L_E_T_ = ' ' "
	cQry += "   AND E5_CLIENTE = '" + cInCod + "' "
	cQry += "   AND E5_LOJA = '" + cInLoja + "' "
	cQry += "   AND E5_MOTBX ='NOR' "
	cQry += "   AND E5_RECPAG ='R' "
	cQry += "   AND E5_TIPODOC NOT IN('JR') "
	cQry += "   AND E5_TIPO NOT IN('RA') "
	cQry += "   AND E5_BANCO IN('341','033') "
	cQry += "   AND E5_DATA >= '" + DTOS(Date()-365) + "' "
	cQry += "   AND E5_FILIAL " + cFilSE5

	TcQuery cQry New Alias "QSE5"

	If !Eof()
		cTextRet 	:=  cValToChar(QSE5->MEDIA_DIAS)
	Endif
	QSE5->(DbCloseArea())

	RestArea(aAreaOld)

Return cTextRet



Static Function sfGetQtePagosBanco(cInCod,cInLoja)
//Valor total pago e quantidade de tĒtulos pagos (portador 341 e 033 - motivo baixa ōNormalö)
	Local 	cTextRet 		:= ""
	Local 	aAreaOld 		:= GetArea()
	Local 	cQry 			:= ""

	cQry := "SELECT SUM(E5_VALOR) VLR_PAGO,COUNT(*) NUM_PAGO  "
	cQry += "  FROM " + RetSqlName("SE5") + " E5 "
	cQry += " WHERE D_E_L_E_T_ = ' ' "
	cQry += "   AND E5_CLIENTE = '" + cInCod + "' "
	cQry += "   AND E5_LOJA = '" + cInLoja + "' "
	cQry += "   AND E5_MOTBX ='NOR' "
	cQry += "   AND E5_RECPAG ='R' "
	cQry += "   AND E5_TIPO NOT IN('RA') "
	cQry += "   AND E5_TIPODOC NOT IN('JR') "
	cQry += "   AND E5_BANCO IN('341','033') "
	cQry += "   AND E5_FILIAL " + cFilSE5

	TcQuery cQry New Alias "QSE5"

	If !Eof()
		cTextRet 	:=  cValToChar(QSE5->NUM_PAGO) + " - R$ " + Alltrim(Transform(QSE5->VLR_PAGO,"@E 999,999,999.99"))
	Endif
	QSE5->(DbCloseArea())

	RestArea(aAreaOld)

Return cTextRet


