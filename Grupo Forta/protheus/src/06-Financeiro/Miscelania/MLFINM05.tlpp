	Local 	cTextRet 		:= ""
	Local 	aAreaOld 		:= GetArea()
	Local 	cQry 			:= ""

	cQry := "SELECT F2_EMISSAO,F2_VALBRUT "
	cQry += "  FROM " + RetSqlName("SF2")
	cQry += " WHERE D_E_L_E_T_ =' ' "
	cQry += "   AND F2_CLIENTE = '" + cInCod + "' "
	cQry += "   AND F2_LOJA = '" + cInLoja + "'  "
	cQry += "   AND F2_FILIAL " + cFilSE1
	cQry += "   AND F2_TIPO = 'N'  "
	cQry += " ORDER BY F2_EMISSAO DESC ,F2_DOC DESC "

	TcQuery cQry New Alias "QSF2"

	If !Eof()
		cTextRet 	:= DTOC(STOD(QSF2->F2_EMISSAO)) + " - R$ " + Alltrim(Transform(QSF2->F2_VALBRUT,"@E 999,999,999.99"))
	Endif
	QSF2->(DbCloseArea())

