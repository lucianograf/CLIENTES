	oGrupo	:= JsonObject():New()
	oGrupo["Grupo"]					:= "Dados_Integracao"
	oGrupo["Nome"]					:= "Vencido_no_Cartao"
	oGrupo["Valor"]					:= sfGetVencidoCartao(SC5->C5_CLIENTE,SC5->C5_LOJACLI,2)
	aUpdTblB5E		:= {}
	Aadd(aUpdTblB5E,{"TB5_CDPROP"	,oBody["CodigoPropostaCliente"]})
	Aadd(aUpdTblB5E,{"TB5_GRUPO"	,oGrupo["Grupo"]})
	Aadd(aUpdTblB5E,{"TB5_NOME"		,oGrupo["Nome"]})
	Aadd(aUpdTblB5E,{"TB5_VALOR"	,oGrupo["Valor"]})
	sfUpdate("T_B2EPROPGR"+cEmpAnt/*cInTble*/,aUpdTblB5E/*aInUpd*/,oGrupo:toJson()/*cInJson*/)
	Aadd(oInfAdicional,oGrupo)
	//-----------------------------------------------------------------------------------------------------------------------------------------------------------

	//Data do ·ltimo pagamento + dias de atraso de tal pagamento (considerar somente portador 341 e 033 e Motivo Baixa ōNormalö para essa informańŃo)
	oGrupo	:= JsonObject():New()
	oGrupo["Grupo"]					:= "Dados_Integracao"
	oGrupo["Nome"]					:= "Data_Ultimo_Pagamento_Banco"
	oGrupo["Valor"]					:= sfGetLastPgto(SC5->C5_CLIENTE,SC5->C5_LOJACLI,2)
	aUpdTblB5E		:= {}
	Aadd(aUpdTblB5E,{"TB5_CDPROP"	,oBody["CodigoPropostaCliente"]})
	Aadd(aUpdTblB5E,{"TB5_GRUPO"	,oGrupo["Grupo"]})
	Aadd(aUpdTblB5E,{"TB5_NOME"		,oGrupo["Nome"]})
	Aadd(aUpdTblB5E,{"TB5_VALOR"	,oGrupo["Valor"]})
	sfUpdate("T_B2EPROPGR"+cEmpAnt/*cInTble*/,aUpdTblB5E/*aInUpd*/,oGrupo:toJson()/*cInJson*/)
	Aadd(oInfAdicional,oGrupo)
	//-----------------------------------------------------------------------------------------------------------------------------------------------------------

	// Limite de crķdito atual 
	oGrupo	:= JsonObject():New()
	oGrupo["Grupo"]					:= "Dados_Integracao"
	oGrupo["Nome"]					:= "Limite_Credito"
	oGrupo["Valor"]					:= Alltrim(Transform(SA1->A1_LC + SA1->A1_LCFIN,"@E 999,999,999.99"))  
	aUpdTblB5E		:= {}
	Aadd(aUpdTblB5E,{"TB5_CDPROP"	,oBody["CodigoPropostaCliente"]})
	Aadd(aUpdTblB5E,{"TB5_GRUPO"	,oGrupo["Grupo"]})
	Aadd(aUpdTblB5E,{"TB5_NOME"		,oGrupo["Nome"]})
	Aadd(aUpdTblB5E,{"TB5_VALOR"	,oGrupo["Valor"]})
	sfUpdate("T_B2EPROPGR"+cEmpAnt/*cInTble*/,aUpdTblB5E/*aInUpd*/,oGrupo:toJson()/*cInJson*/)
	Aadd(oInfAdicional,oGrupo)
	//-----------------------------------------------------------------------------------------------------------------------------------------------------------

	//Total em aberto a vencer no boleto ¢ com portador 341 e 033 ¢ Trazer quantidade e valor
	oGrupo	:= JsonObject():New()
	oGrupo["Grupo"]					:= "Dados_Integracao"
	oGrupo["Nome"]					:= "A_Vencer_no_Boleto"
	oGrupo["Valor"]					:= sfGetAVencerBanco(SC5->C5_CLIENTE,SC5->C5_LOJACLI,2)
	aUpdTblB5E		:= {}
	Aadd(aUpdTblB5E,{"TB5_CDPROP"	,oBody["CodigoPropostaCliente"]})
	Aadd(aUpdTblB5E,{"TB5_GRUPO"	,oGrupo["Grupo"]})
	Aadd(aUpdTblB5E,{"TB5_NOME"		,oGrupo["Nome"]})
	Aadd(aUpdTblB5E,{"TB5_VALOR"	,oGrupo["Valor"]})
	sfUpdate("T_B2EPROPGR"+cEmpAnt/*cInTble*/,aUpdTblB5E/*aInUpd*/,oGrupo:toJson()/*cInJson*/)
	Aadd(oInfAdicional,oGrupo)
	//-----------------------------------------------------------------------------------------------------------------------------------------------------------

	// Total em aberto a vencer no cartŃo ¢ com portador 888, 777, 323, 396, 998, 886 ¢ Trazer quantidade e valor
	oGrupo	:= JsonObject():New()
	oGrupo["Grupo"]					:= "Dados_Integracao"
	oGrupo["Nome"]					:= "A_Vencer_no_Cartao"
	oGrupo["Valor"]					:= sfGetAVencerCartao(SC5->C5_CLIENTE,SC5->C5_LOJACLI,2)
	aUpdTblB5E		:= {}
	Aadd(aUpdTblB5E,{"TB5_CDPROP"	,oBody["CodigoPropostaCliente"]})
	Aadd(aUpdTblB5E,{"TB5_GRUPO"	,oGrupo["Grupo"]})
	Aadd(aUpdTblB5E,{"TB5_NOME"		,oGrupo["Nome"]})
	Aadd(aUpdTblB5E,{"TB5_VALOR"	,oGrupo["Valor"]})
	sfUpdate("T_B2EPROPGR"+cEmpAnt/*cInTble*/,aUpdTblB5E/*aInUpd*/,oGrupo:toJson()/*cInJson*/)
	Aadd(oInfAdicional,oGrupo)
	//-----------------------------------------------------------------------------------------------------------------------------------------------------------


	oBody["InformacoesAdicionais"]			:= oInfAdicional
	cResultPost := HttpPost(cAuthURL,"",EncodeUtf8(oBody:toJson()),120,aHeadOut,@cHeadRet)

	oSonResult:FromJson(cResultPost)
	//{
	//	"Sucesso": true,
	//	"Mensagens": null
	//}
	//[UTF8]"{"Sucesso":false,"Mensagens":[{"Tipo":0,"Codigo":null,"Descricao":"CNPJ invßlido","ValorInformado":null}]}"
	lResult 	:= oSonResult['Sucesso']
	cMsgResult	:= oSonResult["Mensagens"]
	Aadd(aUpdTblB2E,{"TB4_RESULT",Iif(lResult,"Sucesso","Falha") + " - " + Iif(cMsgResult <> Nil,cMsgResult,cHeadRet)})

	sfUpdate("T_B2EPROP"+cEmpAnt/*cInTble*/,aUpdTblB2E/*aInUpd*/,oBody:toJson()/*cInJson*/)

	RestArea(aAreaOld)
Return


/*/{Protheus.doc} sfGetTotPed
FunńŃo para retornar o valor total do pedido 
@type function
@version  
@author Lauschner Consulting - Marcelo Alberto Lauschner
@since 26/04/2025
@param cInNumPed, character, param_description
@return variant, return_description
/*/
Static Function sfGetTotPed(cInNumPed)
	Local 	nValPed 		:= 0
	Local 	aAreaOld 		:= GetArea()
	Local 	cQry 			:= ""

	cQry := "SELECT SUM(C6_VALOR) TOTAL "
	cQry += "  FROM " + RetSqlName("SC6")
	cQry += " WHERE D_E_L_E_T_ =' ' "
	cQry += "   AND C6_NUM = '" + cInNumPed + "' "
	cQry += "   AND C6_BLQ <> 'R' "
	cQry += "   AND C6_QTDENT < C6_QTDVEN "
	cQry += "   AND C6_FILIAL = '" + xFilial("SC6") + "' "

	TcQuery cQry New Alias "QSC6"

	If !Eof()
		nValPed 	:= QSC6->TOTAL
	Endif
	QSC6->(DbCloseArea())

	RestArea(aAreaOld)
Return nValPed


Static Function sfTxtPrdPed(cInNumPed)

	Local 	aAreaOld 		:= GetArea()
	Local 	cQry 			:= ""
	Local 	aRet 			:= {}

	cQry := "SELECT C9_PRODUTO,B1_DESC,SUM(C9_QTDLIB) QTE,SUM(C9_QTDLIB*C9_PRCVEN) TOTAL "
	cQry += "  FROM " + RetSqlName("SC9") + " C9 "
	cQry += " INNER JOIN " + RetSqlName("SB1") + " B1 "
	cQry += "    ON B1.D_E_L_E_T_ = ' ' "
	cQry += "   AND B1_COD = C9_PRODUTO "
	cQry += "   AND B1_FILIAL = '" + xFilial("SB1")+ "' "
	cQry += " WHERE C9.D_E_L_E_T_ = ' ' "
	cQry += "   AND C9_PEDIDO = '" + cInNumPed + "' "
	cQry += "   AND C9_NFISCAL = ' '
	cQry += "   AND C9_FILIAL = '" + xFilial("SC9") + "' "
	cQry += " GROUP BY C9_PRODUTO,B1_DESC "

	TcQuery cQry New Alias "QSC9"

	While !Eof()
		Aadd(aRet,Alltrim(QSC9->C9_PRODUTO) + " - " + Alltrim(QSC9->B1_DESC) + " Qte: " + cValToChar(QSC9->QTE) + " Vlr: R$ " + Alltrim(Transform(QSC9->TOTAL,"@E 999,999,999.99")) )
		QSC9->(DbSkip())
	EndDo
	QSC9->(DbCloseArea())
	RestArea(aAreaOld)

Return aRet

Static Function sfGetSaldoCli(cInCod,cInLoja)
	Local 	nValSE1 		:= 0
	Local 	aAreaOld 		:= GetArea()
	Local 	cQry 			:= ""

	cQry := "SELECT SUM(CASE WHEN E1_TIPO IN('RA','NCC') THEN E1_SALDO * - 1 ELSE E1_SALDO END ) SALDO "
	cQry += "  FROM " + RetSqlName("SE1")
	cQry += " WHERE D_E_L_E_T_ =' ' "
	cQry += "   AND E1_CLIENTE = '" + cInCod + "' "
	cQry += "   AND E1_LOJA = '" + cInLoja + "'  "
	cQry += "   AND E1_FILIAL " + cFilSE1
	cQry += "   AND E1_SALDO > 0 "
	cQry += "   AND E1_STATUS = 'A' "

	TcQuery cQry New Alias "QSE1"

	If !Eof()
		nValSE1 	:= QSE1->SALDO
	Endif
	QSE1->(DbCloseArea())

	RestArea(aAreaOld)

Return nValSE1



Static Function sfGetPrimCompra(cInCod,cInLoja)
	Local 	cTextRet 		:= ""
	Local 	aAreaOld 		:= GetArea()
	Local 	cQry 			:= ""

	cQry := "SELECT F2_EMISSAO,F2_VALBRUT "
	cQry += "  FROM " + RetSqlName("SF2")
	cQry += " WHERE D_E_L_E_T_ =' ' "
	cQry += "   AND F2_CLIENTE = '" + cInCod + "' "
	cQry += "   AND F2_LOJA = '" + cInLoja + "'  "
	cQry += "   AND F2_FILIAL " + cFilSE1
	cQry += "   AND F2_TIPO = 'N'  "
	cQry += " ORDER BY F2_EMISSAO,F2_DOC "

	TcQuery cQry New Alias "QSF2"

	If !Eof()
		cTextRet 	:= DTOC(STOD(QSF2->F2_EMISSAO)) + " - R$ " + Alltrim(Transform(QSF2->F2_VALBRUT,"@E 999,999,999.99"))
	Endif
	QSF2->(DbCloseArea())

	RestArea(aAreaOld)

Return cTextRet



