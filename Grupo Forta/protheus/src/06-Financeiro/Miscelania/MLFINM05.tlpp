Static Function sfIsNewCgc(cInCgc)

	Local 	lRet 	 		:= .F. 
	Local 	aAreaOld 		:= GetArea()
	Local 	cQry 			:= ""

	cQry := "SELECT TB4_PRCGC "
	cQry += "  FROM T_B2EPROP"+cEmpAnt 
	cQry += " WHERE D_E_L_E_T_ =' ' "
	cQry += "   AND TB4_PRCGC = '" + cInCgc + "' "

	TcQuery cQry New Alias "QSE1"

	If !Eof()
		lRet	:= .T. 
	Endif
	QSE1->(DbCloseArea())

	RestArea(aAreaOld)

Return lRet 

/*/{Protheus.doc} sfCreateTblWebHk
FunńŃo para criar tabela de informań§es de retorno do WebHook 
@type function
@version  
@author Lauschner Consulting - Marcelo Alberto Lauschner
@since 26/04/2025
@return variant, return_description
/*/
Static Function sfCreateTblWebHk()

	// Varißvel Array
	Local	aDbStruc 	:= {}
	Local	aArqStruAux	:= {}
	// Varißvel Caractere
	Local	cAlcisTbl	:= "T_B2EWEBHK"+cEmpAnt
	Local 	cRDD 		:= "TOPCONN"
	Local	cIXChave	:= ""
	Local   cIxChv2     := ""

	//T_B2EWEBHK tabela
	//Campos
	Aadd(aDbStruc,{"TB2_NIDUNQ",	"C"	, 30		,	0})    //TB2_NIDUNQ            Sequencial              Tipo 1-Caractere                Tamanho 10              GetSxeNum("T_B2EWEBHK","TB2_NIDUNQ"
	Aadd(aDbStruc,{"TB2_IDB2E" ,	"C"	, 30		,	0})    //TB2_IDB2E             PropostaId B2E          Tipo 1-Caractere                Tamanho: 30
	Aadd(aDbStruc,{"TB2_CDPROP",	"C"	, 30		,	0})    //TB2_CDPROP            CodigoProposta          Tipo 1-Caractere                Tamanho: 30
	Aadd(aDbStruc,{"TB2_CDINST",	"C"	, 30		,	0})    //TB2_CDINST            CodigoInstituicao       Tipo 1-Caractere                Tamanho: 30
	Aadd(aDbStruc,{"TB2_SUCESS",	"C"	, 30		,	0})    //TB2_SUCESS            Sucesso                 Tipo 1-Caractere                Tamanho: 30
	Aadd(aDbStruc,{"TB2_PPROCE",	"C"	, 30		,	0})    //TB2_PPROCE            PropostaProcessada      Tipo 1-Caractere                Tamanho: 30
	Aadd(aDbStruc,{"TB2_STS_ID",	"C"	, 50		,	0})    //TB2_STS_ID            Id                      Tipo 1-Caractere                Tamanho 50
	Aadd(aDbStruc,{"TB2_STS_NM",	"C"	, 52		,	0})    //TB2_STS_NM            Nome                    Tipo 1-Caractere                Tamanho: 50
	Aadd(aDbStruc,{"TB2_STS_DS",	"C"	, 100		,	0})    //TB2_STS_DS            Descricao               Tipo 1-Caractere                Tamanho: 100
	Aadd(aDbStruc,{"TB2_STS_SC",	"N"	, 10		,	0})    //TB2_STS_SC            Score                   Tipo: 2-N·mero                  Tamanho 10             Decimal 0
	Aadd(aDbStruc,{"TB2_STS_LC",	"N"	, 14		,	2})    //TB2_STS_LC            LimiteConcedido         Tipo 2-N·mero                   Tamanho: 14            Decimal: 2
	Aadd(aDbStruc,{"TBX_JSON"  ,	"M"	, 10		,	0})
	Aadd(aDbStruc,{"TBX_DATA"  ,	"D"	, 8			,	0})
	Aadd(aDbStruc,{"TBX_HORA"  ,	"C"	, 8			,	0})

	cIXChave	:= "TB2_CDPROP+TB2_NIDUNQ"
	cIxChv2     := "TB2_NIDUNQ"
	// Verifica se a Tabela existe no Banco de dados

	If !MsFile(cAlcisTbl,, cRDD)
		//TCDelFile(cIdTbl)
		DBCreate(cAlcisTbl, aDbStruc, cRDD)
		DBUseArea( .T., cRDD, cAlcisTbl, (cAlcisTbl), .F./*lShared */, .F./*lReadOnly */ )
		DBCreateIndex(cAlcisTbl+"1",cIXChave,{|| &(cIXChave) })
		DBCreateIndex(cAlcisTbl+"2",cIxChv2,{|| &(cIxChv2) })
		(cAlcisTbl)->(DbCloseArea())
	Else
		Use &(cAlcisTbl) Alias &(cAlcisTbl) SHARED NEW Via cRDD
		aArqStruAux := dbStruct()
		DbCloseArea()

		If sfCompStru(aDbStruc,aArqStruAux)
			If !TcAlter(cAlcisTbl,aArqStruAux,aDbStruc)
				MsgAlert('Alter table in '+cAlcisTbl+' is not possible! ' + TcSqlError(),ProcName(0)+"."+ Alltrim(Str(ProcLine(0))))
				UserException('Alter table in '+cAlcisTbl+' is not possible!')
			Endif
		Endif
	Endif

Return

/*/{Protheus.doc} sfCreateTblWbInfAd
FunńŃo para criar tabela de informań§es adicionais do WebHook  
@type function
@version  
@author Lauschner Consulting - Marcelo Alberto Lauschner
@since 26/04/2025
@return variant, return_description
/*/ 
Static Function sfCreateTblWbInfAd()

	// Varißvel Array
	Local	aDbStruc 	:= {}
	Local	aArqStruAux	:= {}
	// Varißvel Caractere
	Local	cAlcisTbl	:= "T_B2EWEBIA"+cEmpAnt
	Local 	cRDD 		:= "TOPCONN"
	Local	cIXChave	:= ""

	//T_B2EWEBIA tabela
	//Campos
	Aadd(aDbStruc,{"TB3_NIDUNQ" ,	"C"	, 30		,	0})    //TB3_NIDUNQ            Sequencial              Tipo 1-Caractere                Tamanho 10
	Aadd(aDbStruc,{"TB3_ITEM"   ,	"C"	, 03		,	0})    //TB3_ITEM              Item                    Tipo 1-Caractere                Tamanho 3
	Aadd(aDbStruc,{"TB3_TIPO"   ,	"C"	, 01		,	0})    //TB3_TIPO              Item                    Tipo 1-Caractere                Tamanho 3
	Aadd(aDbStruc,{"TB3_GRUPO"  ,	"C"	, 50		,	0})    //TB3_GRUPO             Grupo                   Tipo 1-Caractere                Tamanho 50
	Aadd(aDbStruc,{"TB3_NOME"   ,	"C"	, 50		,	0})    //TB3_GRUPO             Grupo                   Tipo 1-Caractere                Tamanho 50
	Aadd(aDbStruc,{"TB3_VALOR"  ,	"C"	, 150		,	0})    //TB3_VALOR             Valor                   Tipo 1-Caractere                Tamanho 150

	Aadd(aDbStruc,{"TB3_MSGTP"  ,	"N"	, 08		,	0})    //TB3_MSGTP             Grupo                   Tipo 1-Caractere                Tamanho 50
	Aadd(aDbStruc,{"TB3_MSGCD"   ,	"C"	, 50		,	0})    //TB3_GRUPO             Grupo                   Tipo 1-Caractere                Tamanho 50
	Aadd(aDbStruc,{"TB3_MSGDS"  ,	"C"	, 150		,	0})    //TB3_VALOR             Valor                   Tipo 1-Caractere                Tamanho 150
	Aadd(aDbStruc,{"TB3_MSGVI"  ,	"C"	, 150		,	0})    //TB3_VALOR             Valor                   Tipo 1-Caractere                Tamanho 150
	//	"Mensagens": [
	//		{
	//		"Tipo": 0,
	//		"Codigo": "string",
	//		"Descricao": "string",
	//		"ValorInformado": "string"

	Aadd(aDbStruc,{"TBX_JSON"  ,	"M"	, 10		,	0})
	Aadd(aDbStruc,{"TBX_DATA"  ,	"D"	, 8			,	0})
	Aadd(aDbStruc,{"TBX_HORA"  ,	"C"	, 8			,	0})

	cIXChave	:= "TB3_NIDUNQ+TB3_TIPO+TB3_ITEM"
	// Verifica se a Tabela existe no Banco de dados

	If !MsFile(cAlcisTbl,, cRDD)
		//TCDelFile(cIdTbl)
		DBCreate(cAlcisTbl, aDbStruc, cRDD)
		DBUseArea( .T., cRDD, cAlcisTbl, (cAlcisTbl), .F./*lShared */, .F./*lReadOnly */ )
		DBCreateIndex(cAlcisTbl+"1",cIXChave,{|| &(cIXChave) })
		(cAlcisTbl)->(DbCloseArea())
	Else
		Use &(cAlcisTbl) Alias &(cAlcisTbl) SHARED NEW Via cRDD
		aArqStruAux := dbStruct()
		DbCloseArea()

		If sfCompStru(aDbStruc,aArqStruAux)
			If !TcAlter(cAlcisTbl,aArqStruAux,aDbStruc)
				MsgAlert('Alter table in '+cAlcisTbl+' is not possible! ' + TcSqlError(),ProcName(0)+"."+ Alltrim(Str(ProcLine(0))))
				UserException('Alter table in '+cAlcisTbl+' is not possible!')
			Endif
		Endif
	Endif

Return


/*/{Protheus.doc} sfTblWbInfAd
FunńŃo para criar tabela de Informań§es da Proposta 
@type function
@version  
@author Lauschner Consulting - Marcelo Alberto Lauschner
@since 26/04/2025
@return variant, return_description
/*/
Static Function sfTblWbInfAd()

	// Varißvel Array
	Local	aDbStruc 	:= {}
	Local	aArqStruAux	:= {}
	// Varißvel Caractere
	Local	cAlcisTbl	:= "T_B2EPROP"+cEmpAnt
	Local 	cRDD 		:= "TOPCONN"
	Local	cIXChave	:= ""

	//T_B2EPROP tabela
	//Campos
	Aadd(aDbStruc,{"TB4_CDPROP" ,	"C"	, 30		,	0})     //TB4_CDPROP            CodigoPropostaCliente   Tipo 1-Caractere                Tamanho 30
	Aadd(aDbStruc,{"TB4_CDINST" ,	"C"	, 50		,	0})     //TB4_CDINST            CodigoInstituicao       Tipo 1-Caractere                Tamanho 50
	Aadd(aDbStruc,{"TB4_VLRSOL" ,	"N"	, 14		,	2})     //TB4_VLRSOL            ValorSolicitado         Tipo 2-N·mero                   Tamanho 14              Decimal 2
	//Proponente
	Aadd(aDbStruc,{"TB4_PRNOME" ,	"C"	, 70		,	0})     //TB4_PRNOME            RazaoSocial             Tipo 1-Caractere                Tamanho 70
	Aadd(aDbStruc,{"TB4_PRNRED" ,	"C"	, 50		,	0})     //TB4_PRNRED            NomeFantasia            Tipo 1-Caractere                Tamanho 50
	Aadd(aDbStruc,{"TB4_PRCGC"  ,	"C"	, 14		,	0})     //TB4_PRCGC             CNPJ                    Tipo 1-Caractere                Tamanho 14
	Aadd(aDbStruc,{"TB4_PRIE"   ,	"C"	, 30		,	0})     //TB4_PRIE              InscricaoEstadual       Tipo 1-Caractere                Tamanho 30
	Aadd(aDbStruc,{"TB4_PRDFUN" ,	"D"	, 08	   	,	0})     //TB4_PRDFUN            DataFundacao            Tipo 4-Data                     Tamanho 8
	Aadd(aDbStruc,{"TB4_PRNFIL" ,	"N"	, 03 		,	0})     //TB4_PRNFIL            NumeroFiliais+          Tipo 2-Numero                   Tamanho 3
	Aadd(aDbStruc,{"TB4_PRNFUN" ,	"N"	, 04 		,	0})     //TB4_PRNFUN            NumeroFuncionarios      Tipo 2-Numero                   Tamanho 4
	//Enderecos
	Aadd(aDbStruc,{"TB4_EDTIPO" ,	"C"	, 01		,	0})     //TB4_EDTIPO            Tipo                    Tipo 1-Caractere                Tamanho 1
	Aadd(aDbStruc,{"TB4_EDCEP"  ,	"C"	, 09		,	0})     //TB4_EDCEP             CEP                     Tipo 1-Caractere                Tamanho 9
	Aadd(aDbStruc,{"TB4_EDLOGR" ,	"C"	, 50		,	0})     //TB4_EDLOGR            Logradouro              Tipo 1-Caractere                Tamanho 50
	Aadd(aDbStruc,{"TB4_EDNUM"  ,	"C"	, 10		,	0})     //TB4_EDNUM             Numero                  Tipo 1-Caractere                Tamanho 10
	Aadd(aDbStruc,{"TB4_EDCOMP" ,	"C"	, 40		,	0})     //TB4_EDCOMP            Complemento             Tipo 1-Caractere                Tamanho 40
	Aadd(aDbStruc,{"TB4_EDBAIR" ,	"C"	, 50		,	0})     //TB4_EDBAIR            Bairro                  Tipo 1-Caractere                Tamanho 50
	Aadd(aDbStruc,{"TB4_EDMUN"  ,	"C"	, 50		,	0})     //TB4_EDMUN             Cidade                  Tipo 1-Caractere                Tamanho 50
	Aadd(aDbStruc,{"TB4_EDEST"  ,	"C"	, 02		,	0})     //TB4_EDEST             UF                      Tipo 1-Caractere                Tamanho 2
	Aadd(aDbStruc,{"TB4_TFONES" ,	"C"	, 100		,	0})     //TB4_TFONES            Telefones               Tipo 1-Caractere                Tamanho 100
	Aadd(aDbStruc,{"TB4_EMAIL"  ,	"C"	, 150		,	0})     //TB4_EMAIL             Email                   Tipo 1-Caractere                Tamanho 150
	Aadd(aDbStruc,{"TB4_SITE"   ,	"C"	, 150		,	0})     //TB4_SITE              Site                    Tipo 1-Caractere                Tamanho 150
	Aadd(aDbStruc,{"TB4_RATIVD" ,	"C"	, 100		,	0})     //TB4_RATIVD            RamosAtividade          Tipo 1-Caractere                Tamanho 100
	Aadd(aDbStruc,{"TB4_FATMTO" ,	"C"	, 100		,	0})     //TB4_FATMTO            Faturamentos            Tipo 1-Caracatere               Tamanho 100
	Aadd(aDbStruc,{"TB4_REFBCO" ,	"C"	, 250		,	0})     //TB4_REFBCO            ReferenciasBancarias    Tipo 1-Caractere                Tamanho 250
	Aadd(aDbStruc,{"TB4_INFADC" ,	"C"	, 250		,	0})     //TB4_INFADC            InformacoesAdicionais   Tipo 1-Caractere                Tamanho 250
	Aadd(aDbStruc,{"TB4_REPLEG" ,	"C"	, 250		,	0})     //TB4_REPLEG            RepresentantesLegais    Tipo 1-Caractere                Tamanho 250
	Aadd(aDbStruc,{"TB4_RFPCOM" ,	"C"	, 250		,	0})     //TB4_RFPCOM            ReferenciasPessoaisComercial   Tipo 1-Caractere         Tamanho 250

	Aadd(aDbStruc,{"TB4_RESULT" ,	"C" , 250		,   0})
	Aadd(aDbStruc,{"TBX_JSON"  ,	"M"	, 10		,	0})
	Aadd(aDbStruc,{"TBX_DATA"  ,	"D"	, 8			,	0})
	Aadd(aDbStruc,{"TBX_HORA"  ,	"C"	, 8			,	0})

	cIXChave	:= "TB4_CDPROP+TBX_DATA+TBX_HORA"
	cIx2Chave 	:= "TB4_PRCGC+TBX_DATA"
	// Verifica se a Tabela existe no Banco de dados

	If !MsFile(cAlcisTbl,, cRDD)
		//TCDelFile(cIdTbl)
		DBCreate(cAlcisTbl, aDbStruc, cRDD)
		DBUseArea( .T., cRDD, cAlcisTbl, (cAlcisTbl), .F./*lShared */, .F./*lReadOnly */ )
		DBCreateIndex(cAlcisTbl+"1",cIXChave,{|| &(cIXChave) })
		DBCreateIndex(cAlcisTbl+"2",cIx2Chave,{|| &(cIx2Chave) })
		(cAlcisTbl)->(DbCloseArea())
	Else
		Use &(cAlcisTbl) Alias &(cAlcisTbl) SHARED NEW Via cRDD
		aArqStruAux := dbStruct()
		DbCloseArea()

		If sfCompStru(aDbStruc,aArqStruAux)
			If !TcAlter(cAlcisTbl,aArqStruAux,aDbStruc)
				MsgAlert('Alter table in '+cAlcisTbl+' is not possible! ' + TcSqlError(),ProcName(0)+"."+ Alltrim(Str(ProcLine(0))))
				UserException('Alter table in '+cAlcisTbl+' is not possible!')
			Endif
		Endif
	Endif

Return



Static Function sfCreateTblPropInfAd()

	// Varißvel Array
	Local	aDbStruc 	:= {}
	Local	aArqStruAux	:= {}
	// Varißvel Caractere
	Local	cAlcisTbl	:= "T_B2EPROPGR"+cEmpAnt
	Local 	cRDD 		:= "TOPCONN"
	Local	cIXChave	:= ""

	//T_B2EPROPGR tabela
	//Campos
	Aadd(aDbStruc,{"TB5_CDPROP" ,	"C"	, 30		,	0})    //TB3_NIDUNQ            Sequencial              Tipo 1-Caractere                Tamanho 10
	Aadd(aDbStruc,{"TB5_GRUPO"  ,	"C"	, 50		,	0})    //TB3_GRUPO             Grupo                   Tipo 1-Caractere                Tamanho 50
	Aadd(aDbStruc,{"TB5_NOME"   ,	"C"	, 50		,	0})    //TB3_GRUPO             Grupo                   Tipo 1-Caractere                Tamanho 50
	Aadd(aDbStruc,{"TB5_VALOR"  ,	"C"	, 150		,	0})    //TB3_VALOR             Valor                   Tipo 1-Caractere                Tamanho 150


	Aadd(aDbStruc,{"TBX_JSON"  ,	"M"	, 10		,	0})
	Aadd(aDbStruc,{"TBX_DATA"  ,	"D"	, 8			,	0})
	Aadd(aDbStruc,{"TBX_HORA"  ,	"C"	, 8			,	0})

	cIXChave	:= "TB5_CDPROP+TB5_GRUPO+TB5_NOME"
	// Verifica se a Tabela existe no Banco de dados

	If !MsFile(cAlcisTbl,, cRDD)
		//TCDelFile(cIdTbl)
		DBCreate(cAlcisTbl, aDbStruc, cRDD)
		DBUseArea( .T., cRDD, cAlcisTbl, (cAlcisTbl), .F./*lShared */, .F./*lReadOnly */ )
		DBCreateIndex(cAlcisTbl+"1",cIXChave,{|| &(cIXChave) })
		(cAlcisTbl)->(DbCloseArea())
	Else
		Use &(cAlcisTbl) Alias &(cAlcisTbl) SHARED NEW Via cRDD
		aArqStruAux := dbStruct()
		DbCloseArea()

		If sfCompStru(aDbStruc,aArqStruAux)
			If !TcAlter(cAlcisTbl,aArqStruAux,aDbStruc)
				MsgAlert('Alter table in '+cAlcisTbl+' is not possible! ' + TcSqlError(),ProcName(0)+"."+ Alltrim(Str(ProcLine(0))))
				UserException('Alter table in '+cAlcisTbl+' is not possible!')
			Endif
		Endif
	Endif

Return


/*/{Protheus.doc} sfTokNew
FunńŃo para gerar o Token de AutenticańŃo para Cliente Novo
@type function
@version  
@author Lauschner Consulting - Marcelo Alberto Lauschner
@since 26/04/2025
@return variant, return_description
/*/
Static Function sfTokNew()

	Local aHeadOut      := {}
	Local cAuthURL      := "https://sso.b2egroup.com.br/api/tokens"
	Local cParams       := ''
	Local cResultPost   := ''
	Local jAutenticacao := nil
	Local cToken        := ""
	Local cHeadRet      := ''

	cParams := '{"UserName": "usr.svc.grupofortnov","Password": "AlqXgmu@hD1DP1h"}'

	Aadd( aHeadOut,'User-Agent: Mozilla/4.0 (compatible; Protheus ' + GetBuild() + ')' )
	Aadd( aHeadOut,"Content-Type: application/json")

	cResultPost := HttpPost(cAuthURL,"",cParams,120,aHeadOut,@cHeadRet)

	jAutenticacao := JSonObject():New()
	jAutenticacao:FromJson(cResultPost)
	cToken := jAutenticacao['AccessToken']

Return(cToken)

