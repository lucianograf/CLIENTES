        "Descricao": null
    },
    "Score": null,
    "LimiteConcedido": null,
    "Alertas": null,
    "InformacoesAdicionais": []
	}
	*/
	/*
	 {"Sucesso":false,
	  "Mensagens":[{"Tipo":1,"Codigo":"999","Descricao":"Erro ao obter parecer via servi├¦o","ValorInformado":"ERRO: Proposta n├Żo encontrada."}],
	  "CodigoProposta":"202505050401-090130",
	  "PropostaId":null,
	  "PropostaProcessada":false,
	  "StatusProposta":null,
	  "Score":null,
	  "LimiteConcedido":null,
	  "Alertas":null,
	  "InformacoesAdicionais":null}
	*/
	/*
	{	"Sucesso":true,
		"Mensagens":[],
		"CodigoProposta":"202505120401-090522",
		"PropostaId":"200000613850",
		"PropostaProcessada":true,
		"StatusProposta":{	"Id":1,
							"Nome":"AGUARDANDO AN├ØLISE",
							"Descricao":null},
		"Score":959.0000,
		"LimiteConcedido":null,
		"Alertas":[
					{	"Id":null,
						"Descricao":"FILIAL ENVIADA",
						"Resultado":null
					},
					{	"Id":null,
						"Descricao":"CNAE ACEIT├ØVEL",
						"Resultado":false
					},
					{	"Id":null,
						"Descricao":"PONTUALIDADE DE PAGAMENTO SERASA MENOR QUE 85%",
						"Resultado":true
					},
					{	"Id":null,
						"Descricao":"SCORE FUNCIONAL",
						"Resultado":true
					},
					{	"Id":null,
						"Descricao":"SCORE BAIX├ØSSIMO RISCO ",
						"Resultado":true
					},
					{	"Id":null,
						"Descricao":"SITUA├ć├āO CADASTRAL ATIVA",
						"Resultado":true
					},
					{	"Id":null,
						"Descricao":"FUNDA├ć├āO MAIOR IGUAL A 6 MESES",
