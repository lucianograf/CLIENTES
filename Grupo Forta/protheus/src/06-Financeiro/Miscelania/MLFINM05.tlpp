#include "TopConn.ch"
#include "totvs.ch"
/*/{Protheus.doc} MLFINM05
Rotina para gerańŃo integrańŃo com B2E 
@type function
@version  
@author Lauschner Consulting - Marcelo Alberto Lauschner
@since 22/06/2025
@return variant, return_description
/*/
User Function MLFINM05()

	// Cria tabela Webhook
	sfCreateTblWebHk()
	// Cria tabela de Informań§es Adicionais
	sfCreateTblWbInfAd()
	// Cria tabela de Informań§es Proposta
	sfTblWbInfAd()
	// Cria tablea de Informań§es adicionais de proposta
	sfCreateTblPropInfAd()

	// Efetua chamada para retornar Token de Proposta para cliente novo
	//sfTokNew()
	// Efetua chamada para retornar Token de Proposta para cliente jß existente
	//sfTokExist()

	If sfExists("T_B2EPROP"+cEmpAnt/*cInTble*/,SC5->C5_FILIAL + "-" + IIf(!Empty(SC5->C5_IDAJILI),"V"+StrZero(SC5->C5_IDAJILI,8), SC5->C5_NUM )   /* cInDbSeek*/)
		sfGetStsNewProp(SC5->C5_NUM)
	Else
		DbSelectArea("SA1")
		DbSetOrder(1)
		DbSeek(xFilial("SA1")+SC5->C5_CLIENTE + SC5->C5_LOJACLI)

		If !sfIsNewCgc(SA1->A1_CGC)
			sfAddNewProp(SC5->C5_NUM,.T./*lNovoInst*/)
		Else 
			sfAddNewProp(SC5->C5_NUM,.F./*lNovoInst*/) //
		Endif 

		sfGetStsNewProp(SC5->C5_NUM)
	Endif

Return

Static Function sfAddNewProp(cInNumPed,lNovoInst)

	Local 	aAreaOld 		:= GetArea()
	Local 	cToken 			:= ""
	Local 	cCodInst 		:= ""
	Local 	oBody			:= JsonObject():New()
	Local 	oProponente 	:= JsonObject():New()
	Local 	oEnderecos		:= JsonObject():New()
	Local 	oTelefones 		:= JsonObject():New()
	Local 	oInfAdicional	:= {}
	Local 	oGrupo			:= JsonObject():New()
	Local 	oSonResult  	:= JSonObject():New()
	Local 	aHeadOut      	:= {}
	Local 	cAuthURL      	:= "https://cred-api.b2esistemas.com.br/assincrono/v1.0.0/propostaspessoajuridica"
	Local 	cResultPost   	:= ''
	Local 	cHeadRet      	:= ''
	Local 	lResult			:= .F.
	Local 	cMsgResult 		:= ""
	Local 	aUpdTblB2E 		:= {}
	Local 	aUpdTblB5E		:= {}	// Infomrań§es Adicionais
	Local 	nVlrTotPed 		:= 0
	Local 	aItemPed 		:= {}
	Local 	iX
	Private cFilSE1			:= "IN('0101','0201','0301','0401')" //  InstruńŃo SQL para considerar todas as filiais da SE1
	Private cFilSE5 		:= "IN('01  ','02  ','03  ','04  ')" //  InstruńŃo SQL para considerar todas as filiais da SE5


	DbSelectArea("SC5")
	DbSetOrder(1)
	If !DbSeek(xFilial("SC5")+cInNumPed)
		Return
	Endif
	nVlrTotPed	:= sfGetTotPed(cInNumPed)
	If nVlrTotPed <= 0
		Return
	Endif

	If lNovoInst
		cToken 			:= sfTokNew()
		cCodInst		:= "53F8CDBB-265D-4E2F-8D18-66940ED485A6"
	Else
		cToken 			:= sfTokExist()
		cCodInst		:= "5FDADC7A-B503-468C-9628-B4E3B1F8464D"
	Endif

	Aadd( aHeadOut,'User-Agent: PostmanRuntime/7.43.4' )
	Aadd( aHeadOut,"Content-Type: application/json; charset=utf-8")
	Aadd( aHeadOut,'Authorization: Bearer '+cToken)

	DbSelectArea("SA1")
	DbSetOrder(1)
	DbSeek(xFilial("SA1")+SC5->C5_CLIENTE + SC5->C5_LOJACLI)
	//{
	//	"CodigoPropostaCliente": "202504070401-123456",
	oBody["CodigoPropostaCliente"]		:= SC5->C5_FILIAL + "-" + IIf(!Empty(SC5->C5_IDAJILI),"V"+StrZero(SC5->C5_IDAJILI,8), SC5->C5_NUM)  // Data EmissŃo + Filial + N·mero Pedido
	Aadd(aUpdTblB2E,{"TB4_CDPROP",oBody["CodigoPropostaCliente"]})
	//	"CodigoInstituicao": "53F8CDBB-265D-4E2F-8D18-66940ED485A6",
	oBody["CodigoInstituicao"]			:= cCodInst
	Aadd(aUpdTblB2E,{"TB4_CDINST",oBody["CodigoInstituicao"]})
	//	"ValorSolicitado": 1000.80,
	oBody["ValorSolicitado"]			:= nVlrTotPed
	Aadd(aUpdTblB2E,{"TB4_VLRSOL",nVlrTotPed})
	//	"Proponente": {
	//		"RazaoSocial": "Teste de nome",
	oProponente["RazaoSocial"]			:= sfAjust(SA1->A1_NOME/*cInChar*/,/*lOutJson*/,/*lUpper*/)
	Aadd(aUpdTblB2E,{"TB4_PRNOME",oProponente["RazaoSocial"]})
	//		"NomeFantasia": "Nome fantasia",
	oProponente["NomeFantasia"]			:= sfAjust(SA1->A1_NREDUZ/*cInChar*/,/*lOutJson*/,/*lUpper*/)
	Aadd(aUpdTblB2E,{"TB4_PRNRED",oProponente["NomeFantasia"]})
	//		"CNPJ": "94078021000173",
	oProponente["CNPJ"]					:= sfAjust(SA1->A1_CGC/*cInChar*/,/*lOutJson*/,/*lUpper*/)
	Aadd(aUpdTblB2E,{"TB4_PRCGC",oProponente["CNPJ"]})
	//		"InscricaoEstadual": "ISENTO",
	oProponente["InscricaoEstadual"]	:= sfAjust(SA1->A1_INSCR/*cInChar*/,/*lOutJson*/,/*lUpper*/)
	Aadd(aUpdTblB2E,{"TB4_PRIE",oProponente["InscricaoEstadual"]})
	//		"DataFundacao": "2025-01-01",
	oProponente["DataFundacao"]			:= Iif(Empty(SA1->A1_DTNASC),Nil, ( Substr(DTOS(SA1->A1_DTNASC),1,4) + "-" + Substr(DTOS(SA1->A1_DTNASC),5,2) + "-" + Substr(DTOS(SA1->A1_DTNASC),7,2) ))
	Aadd(aUpdTblB2E,{"TB4_PRDFUN",SA1->A1_DTNASC})
	//		"NumeroFiliais": 1,
	oProponente["NumeroFiliais"]		:= 1
	Aadd(aUpdTblB2E,{"TB4_PRNFIL",oProponente["NumeroFiliais"]})
	//		"NumeroFuncionarios": 0,
	oProponente["NumeroFuncionarios"]	:= 0
	Aadd(aUpdTblB2E,{"TB4_PRNFUN",oProponente["NumeroFuncionarios"]})
	//		"Enderecos": [
	//			{
	//				"Tipo": 67,
	oEnderecos["Tipo"]					:= "C"
	Aadd(aUpdTblB2E,{"TB4_EDTIPO",oEnderecos["Tipo"]})
	//				"CEP": "89041-003",
	oEnderecos["CEP"]					:= sfAjust(SA1->A1_CEP/*cInChar*/,/*lOutJson*/,/*lUpper*/)
	Aadd(aUpdTblB2E,{"TB4_EDCEP",oEnderecos["CEP"]})
	//				"Logradouro": "RUA GENERAL,1520",
	oEnderecos["Logradouro"]			:= sfAjust(SA1->A1_END/*cInChar*/,/*lOutJson*/,/*lUpper*/)
	Aadd(aUpdTblB2E,{"TB4_EDLOGR",oEnderecos["Logradouro"]})
	//				"Numero": 0,
	oEnderecos["Numero"]				:= "0"
	Aadd(aUpdTblB2E,{"TB4_EDNUM",oEnderecos["Numero"]})
	//				"Complemento": "RUA",
	oEnderecos["Complemento"]			:= sfAjust(SA1->A1_COMPLEM/*cInChar*/,/*lOutJson*/,/*lUpper*/)
	Aadd(aUpdTblB2E,{"TB4_EDCOMP",oEnderecos["Complemento"]})
	//				"Bairro": "AGUA VERDE",
	oEnderecos["Bairro"]				:= sfAjust(SA1->A1_BAIRRO/*cInChar*/,/*lOutJson*/,/*lUpper*/)
	Aadd(aUpdTblB2E,{"TB4_EDBAIR",oEnderecos["Bairro"]})
	//				"Cidade": "BLUMENAU",
	oEnderecos["Cidade"]				:= sfAjust(SA1->A1_MUN/*cInChar*/,/*lOutJson*/,/*lUpper*/)
	Aadd(aUpdTblB2E,{"TB4_EDMUN",oEnderecos["Cidade"]})
	//				"UF": "SC"
	oEnderecos["UF"]					:= sfAjust(SA1->A1_EST/*cInChar*/,/*lOutJson*/,/*lUpper*/)
	Aadd(aUpdTblB2E,{"TB4_EDEST",oEnderecos["UF"]})
	//			}
	//		],
	//"Telefones": [
	//{
	//"DDD": 0,
	//"Numero": 0,
	//"Ramal": 0,
	//"Tipo": "string"
	//}
	If !Empty(SA1->A1_TEL)
		oProponente["Telefones"]	:= {}
		oTelefones	:= JsonObject():New()
		oTelefones["DDD"]			:= Val(SA1->A1_DDD)
		oTelefones["Numero"]		:= Val(SA1->A1_TEL)
		oTelefones["Ramal"]			:= 0
		oTelefones["Tipo"]			:= ""
		Aadd(oProponente["Telefones"],oTelefones)
	Endif

	If !Empty(SA1->A1_FAX)
		oTelefones	:= JsonObject():New()
		oTelefones["DDD"]			:= Val(SA1->A1_DDD)
		oTelefones["Numero"]		:= Val(SA1->A1_FAX)
		oTelefones["Ramal"]			:= 0
		oTelefones["Tipo"]			:= ""
		Aadd(oProponente["Telefones"],oTelefones)
	Endif

	If !Empty(SA1->A1_TELEX)
		oTelefones	:= JsonObject():New()
		oTelefones["DDD"]			:= Val(SA1->A1_DDD)
		oTelefones["Numero"]		:= Val(SA1->A1_TELEX)
		oTelefones["Ramal"]			:= 0
		oTelefones["Tipo"]			:= ""
		Aadd(oProponente["Telefones"],oTelefones)
	Endif

	//Aadd(aUpdTblB2E,{"TB4_TFONES",oProponente["Telefones"]:ToJson() })
	//		"Email": "NAOSEI@GMAIL.COM",
	oProponente["Email"]				:= sfAjust(SA1->A1_EMAIL/*cInChar*/,/*lOutJson*/,/*lUpper*/)
	Aadd(aUpdTblB2E,{"TB4_EMAIL",oProponente["Email"]})
	//		"Site": "",
	oProponente["Site"]					:= sfAjust(SA1->A1_HPAGE/*cInChar*/,/*lOutJson*/,/*lUpper*/)
	Aadd(aUpdTblB2E,{"TB4_SITE",oProponente["Site"]})
	//		"RamosAtividades": "TESTE DE ATIVIDADE, OU OUTROS TIPOS",
	oProponente["RamosAtividades"]		:= sfAjust(SA1->A1_CNAE/*cInChar*/,/*lOutJson*/,/*lUpper*/) + " " + sfAjust(Posicione("CC3",1,xFilial("CC3")+SA1->A1_CNAE,"CC3_DESC")/*cInChar*/,/*lOutJson*/,/*lUpper*/)
	Aadd(aUpdTblB2E,{"TB4_RATIVD",oProponente["RamosAtividades"]})
	//		"Faturamentos": 10000,
	oProponente["Faturamentos"]			:= SA1->A1_VACUM
	Aadd(aUpdTblB2E,{"TB4_FATMTO",cValToChar(oProponente["Faturamentos"])})
	//		"ReferenciasBancarias": "TESTE DE RERERENCIA PARA SER ╔ CAMPO LIVRE",
	oProponente["ReferenciasBancarias"]	:= ""
	Aadd(aUpdTblB2E,{"TB4_REFBCO",oProponente["ReferenciasBancarias"]})
	//		"InformacoesAdicionais":"OUTRAS INF ADCINOAIS",
	oProponente["InformacoesAdicionais"]:= ""
	Aadd(aUpdTblB2E,{"TB4_INFADC",oProponente["InformacoesAdicionais"]})
	//		"RepresentantesLegais": "FULANO E CIGLANO ",
	oProponente["RepresentantesLegais"]	:= ""
	Aadd(aUpdTblB2E,{"TB4_REPLEG",oProponente["RepresentantesLegais"]})
	//		"ReferenciasPessoaisComercial": "BANCO B2E E INTER"
	oProponente["ReferenciasPessoaisComercial"]	:= ""
	Aadd(aUpdTblB2E,{"TB4_RFPCOM",oProponente["ReferenciasPessoaisComercial"]})
	//	},
	oProponente["Enderecos"]	:= {}
	Aadd(oProponente["Enderecos"],oEnderecos)
	oBody["Proponente"]			:= oProponente

	/*
	INFORMAŪšES DO PEDIDO:
	Precisamos que vß para o B2E as seguintes informań§es do pedido:
	- De qual empresa do grupo forta ķ o pedido
	- Cliente (c¾digo, nome e CNPJ)
	- Valor total do pedido (com frete e difal quando tiver)
	- Banco (se ķ boleto, cartŃo ou a vista)
	- CondińŃo de pagamento (trazer a descrińŃo e nŃo o c¾digo)
	- N·mero do Pedido
	- Produtos e valor por produto
	- Vendedor (trazer o nome do vendedor e nŃo o c¾digo)
	- Observań§es do pedido
	- Necessidade de limite do cliente (total que ele tem em aberto + valor do pedido a ser liberado)
	- Pessoa de contato do pedido (Velis ¢ Ver com Marcelo)
	- Telefone de contato do pedido (Velis ¢ Ver com Marcelo)

	INFORMAŪšES GERAIS PARA IREM PARA O B2E:
	- Valor e data da primeira compra
	- Valor e data da ·ltima compra faturada
	- Valor e data da maior compra faturada
	- Valor e data do maior saldo
	- Limite de crķdito atual e data de vencimento de tal limite no totvs

	Titulos_em_Aberto:
	Trazer informań§es agrupadas de todas as empresas do Grupo Forta ¢ nŃo precisa separar por empresa.
	- Total em aberto vencido no boleto ¢ com portador 341 e 033 ¢ Trazer quantidade e valor
	- Total em aberto a vencer no boleto ¢ com portador 341 e 033 ¢ Trazer quantidade e valor
	- Total em aberto vencido no cartŃo ¢ com portador 888, 777, 323, 396, 998, 886 ¢ Trazer quantidade e valor
	- Total em aberto a vencer no cartŃo ¢ com portador 888, 777, 323, 396, 998, 886 ¢ Trazer quantidade e valor
	- Se tiver tĒtulo vencido, trazer a informańŃo ōdesde quandoö (vencimento mais antigo)

	INFORMAŪšES T═TULOS BAIXADO:
	- Data do ·ltimo pagamento + dias de atraso de tal pagamento (considerar somente portador 341 e 033 e Motivo Baixa ōNormalö para essa informańŃo)
	- Mķdia de dias de atraso dos ·ltimos 12 meses (considerar somente portador 341 e 033 e Motivo Baixa ōNormal para essa informańŃo)
	- Valor total pago e quantidade de tĒtulos pagos (portador 341 e 033 - motivo baixa ōNormalö)
	- Valor total pago e quantidade de tĒtulos pagos (portador 888, 777, 323, 396, 998, 886 - motivo baixa ōNormalö)
	- Valor total e quantidade de RA baixadas por compensańŃo
	*/
	//	"InformacoesAdicionais": [
	//		{
	//			"Grupo": "",

	//De qual empresa do grupo forta ķ o pedido
	oGrupo	:= JsonObject():New()
	oGrupo["Grupo"]					:= "Dados_Pedido"
	oGrupo["Nome"]					:= "Empresa"
	oGrupo["Valor"]					:= cFilAnt + "-" + Alltrim(Capital(SM0->M0_NOMECOM))
	aUpdTblB5E		:= {}
	Aadd(aUpdTblB5E,{"TB5_CDPROP"	,oBody["CodigoPropostaCliente"]})
	Aadd(aUpdTblB5E,{"TB5_GRUPO"	,oGrupo["Grupo"]})
	Aadd(aUpdTblB5E,{"TB5_NOME"		,oGrupo["Nome"]})
	Aadd(aUpdTblB5E,{"TB5_VALOR"	,oGrupo["Valor"]})
	sfUpdate("T_B2EPROPGR"+cEmpAnt/*cInTble*/,aUpdTblB5E/*aInUpd*/,oGrupo:toJson()/*cInJson*/)
	Aadd(oInfAdicional,oGrupo)
	//-----------------------------------------------------------------------------------------------------------------------------------------------------------

	//Cliente (c¾digo, nome e CNPJ)
	oGrupo	:= JsonObject():New()
	oGrupo["Grupo"]					:= "Dados_Pedido"
	oGrupo["Nome"]					:= "Cliente"
	oGrupo["Valor"]					:= Transform(SA1->A1_CGC,"@R 99.999.999/9999-99") + " ( " + SA1->A1_COD + "/" + SA1->A1_LOJA   + ") " + sfAjust(SA1->A1_NOME/*cInChar*/,/*lOutJson*/,/*lUpper*/)
	aUpdTblB5E		:= {}
	Aadd(aUpdTblB5E,{"TB5_CDPROP"	,oBody["CodigoPropostaCliente"]})
	Aadd(aUpdTblB5E,{"TB5_GRUPO"	,oGrupo["Grupo"]})
	Aadd(aUpdTblB5E,{"TB5_NOME"		,oGrupo["Nome"]})
	Aadd(aUpdTblB5E,{"TB5_VALOR"	,oGrupo["Valor"]})
	sfUpdate("T_B2EPROPGR"+cEmpAnt/*cInTble*/,aUpdTblB5E/*aInUpd*/,oGrupo:toJson()/*cInJson*/)
	Aadd(oInfAdicional,oGrupo)
	//-----------------------------------------------------------------------------------------------------------------------------------------------------------

	//Valor total do pedido (com frete e difal quando tiver)
	oGrupo	:= JsonObject():New()
	oGrupo["Grupo"]					:= "Dados_Pedido"
	oGrupo["Nome"]					:= "Valor_Pedido"
	oGrupo["Valor"]					:= "R$ "+Alltrim(Transform(nVlrTotPed + SC5->C5_FRETE ,"@E 999,9999,999.99"))
	aUpdTblB5E		:= {}
	Aadd(aUpdTblB5E,{"TB5_CDPROP"	,oBody["CodigoPropostaCliente"]})
	Aadd(aUpdTblB5E,{"TB5_GRUPO"	,oGrupo["Grupo"]})
	Aadd(aUpdTblB5E,{"TB5_NOME"		,oGrupo["Nome"]})
	Aadd(aUpdTblB5E,{"TB5_VALOR"	,oGrupo["Valor"]})
	sfUpdate("T_B2EPROPGR"+cEmpAnt/*cInTble*/,aUpdTblB5E/*aInUpd*/,oGrupo:toJson()/*cInJson*/)
	Aadd(oInfAdicional,oGrupo)
	//-----------------------------------------------------------------------------------------------------------------------------------------------------------

	//Banco (se ķ boleto, cartŃo ou a vista)
	oGrupo	:= JsonObject():New()
	oGrupo["Grupo"]					:= "Dados_Pedido"
	oGrupo["Nome"]					:= "Banco"
	oGrupo["Valor"]					:= Iif(SC5->C5_BANCO $ "341#033","Boleto -" + SC5->C5_BANCO,Iif(SC5->C5_BANCO $ "777","Vendor - " + SC5->C5_BANCO,IIf(SC5->C5_BANCO $ "888","CartŃo - " + SC5->C5_BANCO,"Banco " + SC5->C5_BANCO)))
	aUpdTblB5E		:= {}
	Aadd(aUpdTblB5E,{"TB5_CDPROP"	,oBody["CodigoPropostaCliente"]})
	Aadd(aUpdTblB5E,{"TB5_GRUPO"	,oGrupo["Grupo"]})
	Aadd(aUpdTblB5E,{"TB5_NOME"		,oGrupo["Nome"]})
	Aadd(aUpdTblB5E,{"TB5_VALOR"	,oGrupo["Valor"]})
	sfUpdate("T_B2EPROPGR"+cEmpAnt/*cInTble*/,aUpdTblB5E/*aInUpd*/,oGrupo:toJson()/*cInJson*/)
	Aadd(oInfAdicional,oGrupo)
	//-----------------------------------------------------------------------------------------------------------------------------------------------------------

	//CondińŃo de pagamento (trazer a descrińŃo e nŃo o c¾digo)
	oGrupo	:= JsonObject():New()
	oGrupo["Grupo"]					:= "Dados_Pedido"
	oGrupo["Nome"]					:= "Condicao_Pagamento"
	oGrupo["Valor"]					:= Alltrim(Posicione("SE4",1,xFilial("SE4")+SC5->C5_CONDPAG,"E4_DESCRI")) + " (" + Alltrim(Posicione("SE4",1,xFilial("SE4")+SC5->C5_CONDPAG,"E4_COND")) + ")"
	aUpdTblB5E		:= {}
	Aadd(aUpdTblB5E,{"TB5_CDPROP"	,oBody["CodigoPropostaCliente"]})
	Aadd(aUpdTblB5E,{"TB5_GRUPO"	,oGrupo["Grupo"]})
	Aadd(aUpdTblB5E,{"TB5_NOME"		,oGrupo["Nome"]})
	Aadd(aUpdTblB5E,{"TB5_VALOR"	,oGrupo["Valor"]})
	sfUpdate("T_B2EPROPGR"+cEmpAnt/*cInTble*/,aUpdTblB5E/*aInUpd*/,oGrupo:toJson()/*cInJson*/)
	Aadd(oInfAdicional,oGrupo)
	//-----------------------------------------------------------------------------------------------------------------------------------------------------------

	//N·mero do Pedido
	oGrupo	:= JsonObject():New()
	oGrupo["Grupo"]					:= "Dados_Pedido"
	oGrupo["Nome"]					:= "Numero_Pedido"
	oGrupo["Valor"]					:= SC5->C5_NUM
	aUpdTblB5E		:= {}
	Aadd(aUpdTblB5E,{"TB5_CDPROP"	,oBody["CodigoPropostaCliente"]})
	Aadd(aUpdTblB5E,{"TB5_GRUPO"	,oGrupo["Grupo"]})
	Aadd(aUpdTblB5E,{"TB5_NOME"		,oGrupo["Nome"]})
	Aadd(aUpdTblB5E,{"TB5_VALOR"	,oGrupo["Valor"]})
	sfUpdate("T_B2EPROPGR"+cEmpAnt/*cInTble*/,aUpdTblB5E/*aInUpd*/,oGrupo:toJson()/*cInJson*/)
	Aadd(oInfAdicional,oGrupo)
	//-----------------------------------------------------------------------------------------------------------------------------------------------------------

	//Produtos e valor por produto
	aItemPed	:=  sfTxtPrdPed(SC5->C5_NUM)

	For iX := 1 To Len(aItemPed)
		oGrupo	:= JsonObject():New()
		oGrupo["Grupo"]					:= "Dados_Pedido"
		oGrupo["Nome"]					:= "Produto_Item_" + StrZero(iX,3)
		oGrupo["Valor"]					:= aItemPed[iX]
		aUpdTblB5E		:= {}
		Aadd(aUpdTblB5E,{"TB5_CDPROP"	,oBody["CodigoPropostaCliente"]})
		Aadd(aUpdTblB5E,{"TB5_GRUPO"	,oGrupo["Grupo"]})
		Aadd(aUpdTblB5E,{"TB5_NOME"		,oGrupo["Nome"]})
		Aadd(aUpdTblB5E,{"TB5_VALOR"	,oGrupo["Valor"]})
		sfUpdate("T_B2EPROPGR"+cEmpAnt/*cInTble*/,aUpdTblB5E/*aInUpd*/,oGrupo:toJson()/*cInJson*/)
		Aadd(oInfAdicional,oGrupo)
	Next
	//-----------------------------------------------------------------------------------------------------------------------------------------------------------

	//Vendedor (trazer o nome do vendedor e nŃo o c¾digo)
	oGrupo	:= JsonObject():New()
	oGrupo["Grupo"]					:= "Dados_Pedido"
	oGrupo["Nome"]					:= "Vendedor"
	oGrupo["Valor"]					:= sfAjust(Posicione("SA3",1,xFilial("SA3")+SC5->C5_VEND1,"A3_NREDUZ")/*cInChar*/,/*lOutJson*/,/*lUpper*/)
	aUpdTblB5E		:= {}
	Aadd(aUpdTblB5E,{"TB5_CDPROP"	,oBody["CodigoPropostaCliente"]})
