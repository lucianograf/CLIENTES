/*/{Protheus.doc} sfCompStru
FunńŃo que verifica se a estrutura da tabela jß existe e se precisa de alguma atualizańŃo. 
@type function
@version  
@author Lauschner Consulting - Marcelo Alberto Lauschner
@since 26/04/2025
@param aTarget, array, param_description
@param aSource, array, param_description
@return variant, return_description
/*/
Static Function sfCompStru(aTarget,aSource)

	// Varißvel L¾gica
	Local lUnlike	:= .F.
	// Varißvel Numķrica
	Local nI		:= 0
	Local nPos		:= 0
	Local nIntS, nIntT

	For nI := 1 To Len( aTarget )
		nPos := Ascan( aSource, { |x| AllTrim( x[1] ) == AllTrim( aTarget [nI][1]) } )
		If ( nPos == 0 )
			lUnlike	:= .T.
		Else
			nIntS := aSource[nPos,3]-aSource[nPos,4]
			nIntT := aTarget[ni,3]-aTarget[ni,4]
			If aSource[npos,2] != "N"
				nIntS := aSource[nPos,3]
			EndIf
			If aTarget[ni,2] != "N"
				nIntT := aTarget[ni,3]
			EndIf
			If ( aSource [nPos][2] == aTarget[nI][2] )
				If nIntT == nIntS
					If ( aSource [nPos][4] <> aTarget[nI][4] )
						lUnlike	:= .T.
					EndIf
				Else
					If ( nIntS > nIntT )

					EndIf
					lUnlike	:= .T.
				EndIf
			Else
				lUnlike	:= .T.
			EndIf
		EndIf
		If ( lUnlike )
			Exit
		EndIf
	Next
	If ( ! lUnlike )
		For nI := 1 To Len( aSource )
			nPos := Ascan( aTarget, { |x| AllTrim( x[1] ) == AllTrim( aSource [nI][1]) } )
			If ( nPos == 0 )
				lUnLike := .T.
			EndIf
		Next
	EndIf

Return( lUnlike )




/*/{Protheus.doc} sfAjust
FunńŃo para ajustar caracteres ao modelo Json
@type function
@version  
@author Lauschner Consulting - Marcelo Alberto Lauschner
@since 26/04/2025
@param cInChar, character, param_description
@param lOutJson, logical, param_description
@return variant, return_description
/*/
Static Function sfAjust(cInChar,lOutJson,lUpper)

	Local	cOut		:= cInChar
	Local	aOut		:= {}
	Local	nO
	Default lOutJson	:= .F.
	Default lUpper 		:= .T.

	Aadd(aOut,{"ß","\u00e1","a"})
	Aadd(aOut,{"Ó","\u00e0","a"})
	Aadd(aOut,{"Ō","\u00e2","a"})
	Aadd(aOut,{"Ń","\u00e3","a"})
	Aadd(aOut,{"õ","\u00e4","a"})
	Aadd(aOut,{"┴","\u00c1","a"})
	Aadd(aOut,{"└","\u00c0","a"})
	Aadd(aOut,{"┬","\u00c2","a"})
	Aadd(aOut,{"├","\u00c3","a"})
	Aadd(aOut,{"─","\u00c4","a"})
	Aadd(aOut,{"ķ","\u00e9","e"})
	Aadd(aOut,{"Ķ","\u00e8","e"})
	Aadd(aOut,{"Ļ","\u00ea","e"})
	Aadd(aOut,{"Ļ","\u00ea","e"})
	Aadd(aOut,{"╔","\u00c9","e"})
	Aadd(aOut,{"╚","\u00c8","e"})
	Aadd(aOut,{"╩","\u00ca","e"})
	Aadd(aOut,{"╦","\u00cb","e"})
	Aadd(aOut,{"Ē","\u00ed","i"})
	Aadd(aOut,{"ņ","\u00ec","i"})
	Aadd(aOut,{"Ņ","\u00ee","i"})
	Aadd(aOut,{"’","\u00ef","i"})
	Aadd(aOut,{"═","\u00cd","i"})
	Aadd(aOut,{"╠","\u00cc","i"})
	Aadd(aOut,{"╬","\u00ce","i"})
	Aadd(aOut,{"Ž","\u00cf","i"})
	Aadd(aOut,{"¾","\u00f3","o"})
	Aadd(aOut,{"“","\u00f2","o"})
	Aadd(aOut,{"¶","\u00f4","o"})
	Aadd(aOut,{"§","\u00f5","o"})
	Aadd(aOut,{"÷","\u00f6","o"})
	Aadd(aOut,{"ė","\u00d3","o"})
	Aadd(aOut,{"ę","\u00d2","o"})
	Aadd(aOut,{"į","\u00d4","o"})
	Aadd(aOut,{"š","\u00d5","o"})
	Aadd(aOut,{"ų","\u00d6","o"})
	Aadd(aOut,{"·","\u00fa","u"})
	Aadd(aOut,{"∙","\u00f9","u"})
	Aadd(aOut,{"¹","\u00fb","u"})
	Aadd(aOut,{"³","\u00fc","u"})
	Aadd(aOut,{"┌","\u00da","u"})
	Aadd(aOut,{"┘","\u00d9","u"})
	Aadd(aOut,{"█","\u00db","u"})
	Aadd(aOut,{"ń","\u00e7","c"})
	Aadd(aOut,{"Ū","\u00c7","c"})
	Aadd(aOut,{"±","\u00f1","n"})
	Aadd(aOut,{"č","\u00d1","n"})
	Aadd(aOut,{"«","\u00d1","r"})
	Aadd(aOut,{"░","\u00d1"," "})
	Aadd(aOut,{"¬","\u00d1"," "})
	Aadd(aOut,{Chr(186),"\u00d1"," "})
	Aadd(aOut,{"┤","\u00b4"," "})
	Aadd(aOut,{Chr(13),"\u0013"," "})
	Aadd(aOut,{Chr(10),"\u0010"," "})
	Aadd(aOut,{"/","\u0010","-"})

	Aadd(aOut,{"&","\u0026"," ","&amp;"})
	Aadd(aOut,{"<","\u0010"," ","&lt;"})
	Aadd(aOut,{">","\u0010"," ","&gt;"})
	Aadd(aOut,{'"',"\u0010"," ","&quot;"})
	Aadd(aOut,{"'","\u0027"," ","&#39;"})
	Aadd(aOut,{"ž","\u00d8"," "," "})
	Aadd(aOut,{"Į","\u00d8"," "," "})

	//U_MLFWLMSG("+------------------------------------+")
	//U_MLFWLMSG(cOut)
	If lOutJson
		For nO := 1 To Len(aOut)
			cOut	:= StrTran(cOut,aOut[nO,1],aOut[nO,2])
		Next nO
		If lUpper
			cOut	:= Alltrim(cOut)
		Else

		Endif
	Else
		//cOut	:= DecodeUTF8(cOut)
		//U_MLFWLMSG(cOut)

		For nO := 1 To Len(aOut)
			cOut	:= StrTran(cOut,aOut[nO,1],aOut[nO,3])
		Next nO
		If lUpper
			cOut	:= Alltrim(Upper(cOut))
		Else
			cOut	:= Alltrim(cOut)
		Endif
	Endif
	//U_MLFWLMSG(cInChar)
	//U_MLFWLMSG(cOut)
	//U_MLFWLMSG("+++------------------------------------+")

Return cOut



Static Function sfUpdate(cInTble,aInUpd,cInJson)
	// Varißvel Caractere
	Local 	cRDD 		:= "TOPCONN"
	Local	cIdTbl		:= GetNextAlias() // Usa outro Id de Tabela para evitar erro
	Local 	nx

	DBUseArea( .T., cRDD, cInTble, (cIdTbl), .T./*lShared */, .F./*lReadOnly */ )

	(cIdTbl)->( DBClearIndex() ) //Forńa o fechamento dos indices abertos

	dbSetIndex(cInTble+"1")	 //acrescenta a ordem de indice para a ßrea aberta

	(cIdTbl)->(DBAppend( .F. ))

	For nX := 1 To Len(aInUpd)
		&("(cIdTbl)->" + aInUpd[nX][1] )	:= aInUpd[nX][2]
	Next

	(cIdTbl)->TBX_JSON		:= cInJson	//",	"M"	, 10	,	0})
	(cIdTbl)->TBX_DATA		:= Date()	//",	"D"	, 8		,	0})
	(cIdTbl)->TBX_HORA		:= Time()	//",	"C"	, 8		,	0})

	(cIdTbl)->(MsUnlock())
	(cIdTbl)->(DBCommit())
	(cIdTbl)->(DbCloseArea())

Return

Static Function sfExists(cInTble,cInDbSeek)
	// Varißvel Caractere
	Local 	cRDD 		:= "TOPCONN"
	Local	cIdTbl		:= GetNextAlias() // Usa outro Id de Tabela para evitar erro
	Local 	lRet 		:= .F.

	DBUseArea( .T., cRDD, cInTble, (cIdTbl), .T./*lShared */, .F./*lReadOnly */ )

	(cIdTbl)->( DBClearIndex() ) //Forńa o fechamento dos indices abertos

	dbSetIndex(cInTble+"1")	 //acrescenta a ordem de indice para a ßrea aberta

	If DbSeek(cInDbSeek)
		lRet 	:= .T.
	Endif
	(cIdTbl)->(DbCloseArea())

Return lRet


Static Function sfGetStsNewProp(cInNumPed)

	Local 		aHeader 	:= {}
	Local 		cUrl 		:= "https://cred-api.b2esistemas.com.br/parecer/v1.0.0/pareceres?"
	Local 		cCodInst 	:= "53F8CDBB-265D-4E2F-8D18-66940ED485A6"
	Local 		cCodPerg 	:= "codigoInstituicao=" + cCodInst
	Local 		cCodProp	:= "codigoProposta="  //202504070401-123456"
	Local 		cGetParms 	:= ""
	Local 		nTimeOut 	:= 120
	Local 		cHeaderGet 	:= ""
	Local 		cToken		:= sfTokNew()
	Local 		aUpdTblB2E	:= {}
	Local 		nX
	Local 		cUnqTb2 	:= xFilial("SC5")+cInNumPed+DTOS(Date())+StrTran(Time(),":")

	DbSelectArea("SC5")
	DbSetOrder(1)
	If !DbSeek(xFilial("SC5")+cInNumPed)
		Return
	Endif

	cCodProp += SC5->C5_FILIAL + "-" + IIf(!Empty(SC5->C5_IDAJILI),"V"+StrZero(SC5->C5_IDAJILI,8), SC5->C5_NUM)

	Aadd( aHeader,'User-Agent: Mozilla/4.0 (compatible; Protheus ' + GetBuild() + ')' )
	Aadd( aHeader,"Content-Type: application/json")
	Aadd( aHeader,'Authorization: Bearer '+cToken)

	cRetorno := HttpGet( cUrl + cCodPerg + "&" + cCodProp , cGetParms, nTimeOut, aHeader, @cHeaderGet )

	If ValType(cRetorno) <> "C"
		MsgAlert("Erro de acesso a pßgina de Pedidos '" +cUrl +"'. Favor contatar o TI.", ProcName(0)+"."+ Alltrim(Str(ProcLine(0))))
		Return
	Endif

	jRet := JSonObject():New()
	jRet:FromJson(cRetorno)

	/*
	{
    "Sucesso": true,
    "Mensagens": [],
    "CodigoProposta": "202504070401-123456",
    "PropostaId": "200000581212",
