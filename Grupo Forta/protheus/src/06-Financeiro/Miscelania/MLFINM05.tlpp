Static Function sfGetMaiorSaldo(cInCod,cInLoja)
	Local 	cTextRet 		:= ""
	Local 	aAreaOld 		:= GetArea()
	Local 	cQry 			:= ""

	cQry := "SELECT DISTINCT E1_EMISSAO,E1_FILIAL,"
	cQry += "        (SELECT SUM(E1_VALOR) "
	cQry += "           FROM " + RetSqlName("SE1") + " E1B  "
	cQry += "          WHERE E1B.D_E_L_E_T_ =' ' "
	cQry += "            AND E1B.E1_EMISSAO <= E1A.E1_EMISSAO "
	cQry += "            AND E1B.E1_BAIXA > E1A.E1_EMISSAO  "
	cQry += "            AND  E1B.E1_CLIENTE = E1A.E1_CLIENTE "
	cQry += "            AND E1B.E1_LOJA =E1A.E1_LOJA "
	cQry += "            AND E1B.E1_FILIAL = E1A.E1_FILIAL) VALOR "
	cQry += "  FROM " + RetSqlName("SE1") + " E1A "
	cQry += " WHERE E1A.D_E_L_E_T_ =' ' "
	cQry += "   AND E1_TIPO NOT IN('RA','NCC')"
	cQry += "   AND E1_CLIENTE = '" + cInCod + "' "
	cQry += "   AND E1_LOJA = '" + cInLoja + "' "
	cQry += "   AND E1_FILIAL " + cFilSE1
	cQry += " ORDER BY 3 DESC "

	TcQuery cQry New Alias "QSE1"

	If !Eof()
		cTextRet 	:= DTOC(STOD(QSE1->E1_EMISSAO)) + " - R$ " + Alltrim(Transform(QSE1->VALOR,"@E 999,999,999.99"))
	Endif
	QSE1->(DbCloseArea())

	RestArea(aAreaOld)

Return cTextRet




Static Function sfGetVencidoBanco(cInCod,cInLoja,nInOpc)
	Local 	cTextRet 		:= ""
	Local 	aAreaOld 		:= GetArea()
	Local 	cQry 			:= ""

	cQry := "SELECT COUNT(*) QTE,SUM(E1_SALDO) SALDO"
	cQry += "  FROM " + RetSqlName("SE1") + " E1A "
	cQry += " WHERE E1A.D_E_L_E_T_ =' ' "
	cQry += "   AND E1_TIPO NOT IN('RA','NCC')"
	cQry += "   AND E1_PORTADO IN('341','033')"
	cQry += "   AND E1_CLIENTE = '" + cInCod + "' "
	cQry += "   AND E1_LOJA = '" + cInLoja + "' "
	cQry += "   AND E1_FILIAL " + cFilSE1
	cQry += "   AND E1_SALDO > 0 "
	cQry += "   AND E1_STATUS = 'A' "
	cQry += "   AND E1_VENCREA < '" + DTOS(Date()) + "' "

	TcQuery cQry New Alias "QSE1"

	If !Eof()
		If nInOpc == 1 
			cTextRet 	:= cValToChar(QSE1->QTE) + " - R$ " + Alltrim(Transform(QSE1->SALDO,"@E 999,999,999.99"))
		ElseIf nInOpc == 2 
			cTextRet 	:= Alltrim(Transform(QSE1->SALDO,"@E 999,999,999.99"))
		Endif 
	Endif
	QSE1->(DbCloseArea())

	RestArea(aAreaOld)

Return cTextRet


